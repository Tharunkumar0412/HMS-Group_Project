extends layouts/main

block content
  div(class="flex min-h-screen bg-green-50")
    //- Sidebar
    aside(class="w-64 bg-green-800 text-white p-6 hidden md:flex flex-col justify-between shadow-lg")
      div
        h2(class="text-xl font-bold mb-10 border-b border-green-700 pb-4") HMS-Care
        nav(class="space-y-4")
          a(href="/dashboard/patient" class="block p-2 hover:bg-green-700 rounded transition-colors") Dashboard
          a(href="#" class="block p-2 hover:bg-green-700 rounded transition-colors") Patient Records 
          a(href="/booking/new" class="block bg-green-700 p-2 rounded transition-colors") Appointments 
      
      div(class="pt-10")
        a(href="/auth/logout" class="block w-full text-center bg-red-600 hover:bg-red-700 p-2 rounded font-bold transition-all shadow-md hover:shadow-lg") Logout

    //- Main Booking Content
    main(class="flex-1 p-8")
      header(class="flex justify-between items-center mb-10")
        div
          h2(class="text-2xl font-bold text-green-900") Book an Appointment
          p(class="text-sm text-green-700 font-medium mt-1") Follow the steps below to schedule your visit with our specialists
        div(class="flex items-center gap-3")
          span(class="font-bold text-green-900") #{user.name}
          span(class="text-[10px] text-green-800 font-bold px-2 py-1 bg-green-200 rounded-full uppercase") Patient

      //- Booking Steps Indicator
      div(class="max-w-4xl mx-auto mb-10")
        div(class="flex items-center justify-between relative before:absolute before:inset-0 before:top-1/2 before:-translate-y-1/2 before:h-0.5 before:w-full before:bg-green-200 before:-z-10")
          div(class="flex flex-col items-center bg-green-50 px-2")
            div#step1Indicator(class="w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm shadow-md transition-colors") 1
            span(class="text-xs font-bold text-green-800 mt-2") Department
          div(class="flex flex-col items-center bg-green-50 px-2")
            div#step2Indicator(class="w-8 h-8 rounded-full bg-white border-2 border-green-200 text-slate-400 flex items-center justify-center font-bold text-sm transition-colors") 2
            span(class="text-xs font-bold text-slate-400 mt-2") Choose Doctor
          div(class="flex flex-col items-center bg-green-50 px-2")
            div(class="w-8 h-8 rounded-full bg-white border-2 border-green-200 text-slate-400 flex items-center justify-center font-bold text-sm transition-colors") 3
            span(class="text-xs font-bold text-slate-400 mt-2") Confirm

      //- Interactive Form
      form(action="/booking/confirm" method="POST" id="bookingForm" class="max-w-4xl mx-auto bg-white p-8 rounded-2xl shadow-sm border border-green-100")
        
        //- STEP 1: Department Selection Grid
        div#step1
          h3(class="text-lg font-bold text-green-800 mb-6 text-center") Select a Specialty
          div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6")
            each dept in departments
              label(class="cursor-pointer group relative")
                input(type="radio" name="department" value=dept.id class="peer sr-only")
                div(class="h-full p-6 border-2 border-slate-100 rounded-xl text-center transition-all peer-checked:border-green-600 peer-checked:bg-green-50 hover:border-green-300 hover:bg-slate-50")
                  div(class="w-12 h-12 mx-auto bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-4 text-2xl") #{dept.icon}
                  h4(class="font-bold text-slate-800 mb-1") #{dept.name}
                  p(class="text-[11px] text-slate-500 leading-tight") #{dept.desc}
          
          div(class="mt-10 pt-6 border-t border-slate-100 flex justify-end")
            button(type="button" onclick="nextStep(2)" class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-lg font-bold transition-all shadow-md inline-block") Continue
        
        //- STEP 2: Doctor and Time Selection
        div#step2(class="hidden")
          h3(class="text-lg font-bold text-green-800 mb-6 text-center") Choose Doctor & Time Slot
          div(class="max-w-md mx-auto space-y-6")
            div
              label(class="block text-sm font-bold text-slate-700 mb-2") Preferred Date
              input(type="date" name="date" required class="w-full px-4 py-3 rounded-lg border border-green-200 outline-none focus:ring-2 focus:ring-green-500")
            
            div
              label(class="block text-sm font-bold text-slate-700 mb-2") Select Specialist
              select(name="doctor" required class="w-full px-4 py-3 rounded-lg border border-green-200 outline-none focus:ring-2 focus:ring-green-500 bg-white")
                option(value="" disabled selected) Select a doctor...
                each doc in doctors
                  option(value=doc.name) #{doc.name}
            
            div
              label(class="block text-sm font-bold text-slate-700 mb-2") Select Time
              select(name="timeSlot" required class="w-full px-4 py-3 rounded-lg border border-green-200 outline-none focus:ring-2 focus:ring-green-500 bg-white")
                option(value="" disabled selected) Select available time...
                option(value="09:00 AM") 09:00 AM
                option(value="10:30 AM") 10:30 AM
                option(value="02:00 PM") 02:00 PM
                option(value="04:15 PM") 04:15 PM

          div(class="mt-10 pt-6 border-t border-slate-100 flex justify-between")
            button(type="button" onclick="nextStep(1)" class="px-6 py-3 font-bold text-slate-500 hover:text-slate-800 transition-colors") Back
            button(type="submit" class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-lg font-bold transition-all shadow-md inline-block") Confirm Booking

  script.
    function nextStep(step) {
      const step1Div = document.getElementById('step1');
      const step2Div = document.getElementById('step2');
      const step2Ind = document.getElementById('step2Indicator');

      if(step === 2) {
        // Validate radio button selection before allowing transition
        const deptSelected = document.querySelector('input[name="department"]:checked');
        if(!deptSelected) {
          alert("Please select a department to continue.");
          return;
        }
        
        // Hide Step 1, Show Step 2
        step1Div.classList.add('hidden');
        step2Div.classList.remove('hidden');
        
        // Update Indicator styling
        step2Ind.className = "w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm shadow-md transition-colors";
      } else if(step === 1) {
        // Hide Step 2, Show Step 1
        step2Div.classList.add('hidden');
        step1Div.classList.remove('hidden');
        
        // Revert Indicator styling
        step2Ind.className = "w-8 h-8 rounded-full bg-white border-2 border-green-200 text-slate-400 flex items-center justify-center font-bold text-sm transition-colors";
      }
    }