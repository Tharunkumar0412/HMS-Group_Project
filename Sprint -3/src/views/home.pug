extends layouts/main

block content
  div(class="min-h-screen bg-slate-50 font-sans selection:bg-green-200 selection:text-green-900")
    
    //- Navigation Bar
    nav(class="bg-white border-b border-slate-100 sticky top-0 z-50 shadow-sm")
      div(class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between")
        div(class="flex items-center gap-3")
          span(class="text-3xl") 
          span(class="text-2xl font-black text-green-900 tracking-tight") HMS-Care
        
        div(class="hidden md:flex items-center gap-8 text-sm font-bold text-slate-600")
          a(href="#" class="hover:text-green-600 transition-colors") About Us
          a(href="#" class="hover:text-green-600 transition-colors") Departments
          a(href="#" class="hover:text-green-600 transition-colors") Doctors
          a(href="#" class="hover:text-green-600 transition-colors") Contact
        
        div(class="flex items-center gap-4")
          a(href="/login" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-md shadow-green-200 flex items-center gap-2 hover:-translate-y-0.5")
            span 
            span Access Portal

    //- Hero Section
    section(class="relative bg-white overflow-hidden")
      div(class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24 lg:pt-32 lg:pb-40 flex flex-col lg:flex-row items-center gap-12")
        
        //- Hero Text Content
        div(class="flex-1 text-center lg:text-left z-10")
          div(class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-50 border border-green-100 text-green-700 text-xs font-bold uppercase tracking-widest mb-6")
            span(class="w-2 h-2 rounded-full bg-green-500 animate-pulse")
            | 24/7 Emergency Care
          
          h1(class="text-4xl md:text-5xl lg:text-6xl font-black text-slate-900 leading-tight mb-6")
            | Advanced Healthcare, 
            br
            span(class="text-transparent bg-clip-text bg-gradient-to-r from-green-600 to-blue-600") Compassionate Care.
          
          p(class="text-lg text-slate-500 mb-10 max-w-2xl mx-auto lg:mx-0 leading-relaxed font-medium")
            | Experience world-class medical facilities with HMS-Care. Our integrated portal connects patients directly to our expert medical staff, ensuring seamless communication and rapid recovery.
          
          div(class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4")
            a(href="/login" class="w-full sm:w-auto bg-slate-900 hover:bg-slate-800 text-white px-8 py-4 rounded-xl font-bold transition-all shadow-lg flex items-center justify-center gap-3 text-lg")
              span Patient Portal
              span →
            a(href="/login" class="w-full sm:w-auto bg-white border-2 border-slate-200 hover:border-green-600 hover:text-green-700 text-slate-700 px-8 py-4 rounded-xl font-bold transition-all flex items-center justify-center gap-3 text-lg")
              span Staff Login

        //- Hero Image (Using a high-quality Unsplash hospital image)
        div(class="flex-1 relative w-full max-w-lg lg:max-w-none mx-auto")
          div(class="absolute inset-0 bg-gradient-to-tr from-green-100 to-blue-50 rounded-[3rem] transform rotate-3 scale-105 -z-10")
          img(src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Modern Hospital Facility" class="rounded-[3rem] shadow-2xl border-8 border-white object-cover h-[400px] lg:h-[600px] w-full")
          
          //- Floating Stats Card on Image
          div(class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-4 animate-bounce-slow")
            div(class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-2xl") 🏆
            div
              p(class="text-sm font-bold text-slate-500 uppercase tracking-wider") Award Winning
              p(class="text-lg font-black text-slate-800") Top 10 Hospitals

    //- Quick Stats Section
    section(class="bg-green-900 py-16")
      div(class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8")
        div(class="grid grid-cols-2 md:grid-cols-4 gap-8 divide-x divide-green-800 text-center")
          div
            p(class="text-4xl font-black text-white mb-2") 50+
            p(class="text-green-300 font-bold text-sm uppercase tracking-widest") Expert Doctors
          div
            p(class="text-4xl font-black text-white mb-2") 10k+
            p(class="text-green-300 font-bold text-sm uppercase tracking-widest") Patients Treated
          div
            p(class="text-4xl font-black text-white mb-2") 15+
            p(class="text-green-300 font-bold text-sm uppercase tracking-widest") Years Experience
          div
            p(class="text-4xl font-black text-white mb-2") 24/7
            p(class="text-green-300 font-bold text-sm uppercase tracking-widest") Emergency Care

    //- Services Section
    section(class="py-24 bg-slate-50")
      div(class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8")
        div(class="text-center mb-16")
          h2(class="text-3xl font-black text-slate-900 mb-4") Centers of Excellence
          p(class="text-slate-500 font-medium max-w-2xl mx-auto") We provide highly specialized medical care across various departments using state-of-the-art technology.
        
        div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8")
          //- Service Card 1
          div(class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 hover:shadow-xl hover:-translate-y-2 transition-all group")
            div(class="w-14 h-14 bg-red-50 text-red-600 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform") ❤️
            h3(class="text-xl font-bold text-slate-800 mb-3") Cardiology
            p(class="text-slate-500 text-sm leading-relaxed mb-6") Comprehensive care for heart diseases, featuring advanced catheterization labs and bypass surgeries.
            a(href="/login" class="text-green-600 font-bold text-sm flex items-center gap-2 group-hover:text-green-700") Book Appointment <span>→</span>
          
          //- Service Card 2
          div(class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 hover:shadow-xl hover:-translate-y-2 transition-all group")
            div(class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform") 🧠
            h3(class="text-xl font-bold text-slate-800 mb-3") Neurology
            p(class="text-slate-500 text-sm leading-relaxed mb-6") Expert treatment for brain, spinal cord, and nervous system disorders with advanced neuroimaging.
            a(href="/login" class="text-green-600 font-bold text-sm flex items-center gap-2 group-hover:text-green-700") Book Appointment <span>→</span>
          
          //- Service Card 3
          div(class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 hover:shadow-xl hover:-translate-y-2 transition-all group")
            div(class="w-14 h-14 bg-orange-50 text-orange-600 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform") 🦴
            h3(class="text-xl font-bold text-slate-800 mb-3") Orthopedics
            p(class="text-slate-500 text-sm leading-relaxed mb-6") Specialized care for bones, joints, and ligaments. We offer advanced robotic joint replacement surgery.
            a(href="/login" class="text-green-600 font-bold text-sm flex items-center gap-2 group-hover:text-green-700") Book Appointment <span>→</span>

    //- Footer
    footer(class="bg-slate-900 py-12 border-t border-slate-800")
      div(class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center")
        p(class="text-slate-400 font-medium mb-4") © 2024 HMS-Care. All rights reserved.
        div(class="flex justify-center gap-6 text-sm font-bold text-slate-500")
          a(href="#" class="hover:text-white transition-colors") Privacy Policy
          a(href="#" class="hover:text-white transition-colors") Terms of Service
          a(href="/login" class="hover:text-white transition-colors text-green-500") Staff Portal Login