extends layouts/main

block content
  div(class="flex min-h-screen bg-green-50")
    //- Sidebar
    aside(class="w-64 bg-green-800 text-white p-6 hidden md:flex flex-col justify-between shadow-lg")
      div
        h2(class="text-xl font-bold mb-10 border-b border-green-700 pb-4") HMS-Care
        nav(class="space-y-4")
          a(href="/dashboard/patient" class="block p-2 hover:bg-green-700 rounded transition-colors") Dashboard
          //- Highlighted active state for Records
          a(href="/dashboard/patient/records" class="block bg-green-700 p-2 rounded transition-colors font-bold") Patient Records 
          a(href="/booking/new" class="block p-2 hover:bg-green-700 rounded transition-colors") Appointments 
      
      div(class="pt-10")
        a(href="/auth/logout" class="block w-full text-center bg-red-600 hover:bg-red-700 p-2 rounded font-bold transition-all shadow-md hover:shadow-lg") Logout

    //- Main Content
    main(class="flex-1 p-8")
      //- Header corresponding to the wireframe 
      header(class="bg-white p-6 rounded-2xl shadow-sm border border-green-100 mb-8 flex items-center justify-between")
        div(class="flex items-center gap-6")
          div(class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-3xl font-bold") A
          div
            div(class="flex items-center gap-3 mb-1")
              h2(class="text-2xl font-bold text-slate-800") #{user.name}
              span(class="text-xs font-bold text-slate-500 bg-slate-100 px-2 py-1 rounded-md") P-#{user.id}
            div(class="flex items-center gap-4 text-sm text-slate-500 font-medium")
              span #{user.age} years • #{user.gender}
              span(class="flex items-center gap-1") <span class="text-red-500">🩸</span> Blood Group: #{user.bloodGroup}
              span Last Visit: #{user.lastVisit}
        
        button(class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-lg font-bold transition-all shadow-sm") Download Full History

      div(class="grid grid-cols-1 lg:grid-cols-3 gap-8")
        //- Left Column: Diagnoses & Medications
        div(class="col-span-2 space-y-8")
          
          //- Active Diagnoses 
          section(class="bg-white p-6 rounded-2xl shadow-sm border border-green-100")
            h3(class="text-sm font-bold text-green-600 mb-6 flex items-center gap-2") 
              span 📋
              | ACTIVE DIAGNOSES
            
            div(class="divide-y divide-slate-100")
              each diag in user.activeDiagnoses
                div(class="py-4 first:pt-0 last:pb-0 flex justify-between items-center hover:bg-green-50 px-2 rounded-lg transition-colors cursor-pointer")
                  div
                    p(class="font-bold text-slate-800") #{diag.name}
                    p(class="text-xs text-slate-500 mt-1") Diagnosed: #{diag.date}
                  span(class="text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider " + (diag.status === 'Active' ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-600')) #{diag.status}

          //- Prescribed Medications 
          section(class="bg-white p-6 rounded-2xl shadow-sm border border-green-100")
            h3(class="text-sm font-bold text-green-600 mb-6 flex items-center gap-2") 
              span 💊
              | PRESCRIBED MEDICATIONS
            
            div(class="space-y-3")
              each med in user.medications
                div(class="flex items-center gap-4 p-4 border border-slate-100 rounded-xl hover:border-green-200 hover:shadow-sm transition-all")
                  div(class="w-10 h-10 rounded-full bg-green-50 flex items-center justify-center text-green-600") 🔗
                  div
                    p(class="font-bold text-slate-800") #{med.name}
                    p(class="text-xs text-slate-500 mt-1") #{med.instructions}

        //- Right Column: Files & Allergies
        div(class="space-y-8")
          
          //- Known Allergies 
          section(class="bg-red-50 p-6 rounded-2xl shadow-sm border border-red-100")
            h3(class="text-sm font-bold text-red-600 mb-4 flex items-center gap-2 uppercase tracking-widest") 
              span ⚠️
              | Known Allergies
            div(class="flex flex-wrap gap-2")
              each allergy in user.allergies
                if allergy.type === 'danger'
                  span(class="bg-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg shadow-sm") #{allergy.name}
                else
                  span(class="bg-orange-100 text-orange-800 border border-orange-200 text-xs font-bold px-3 py-1.5 rounded-lg") #{allergy.name}

          //- Medical Files 
          section(class="bg-white p-6 rounded-2xl shadow-sm border border-green-100")
            h3(class="text-sm font-bold text-green-600 mb-6 flex items-center gap-2") 
              span 
              | MEDICAL FILES
            
            div(class="space-y-4")
              each file in user.medicalFiles
                div(class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100 hover:bg-green-50 transition-colors cursor-pointer group")
                  div(class="flex items-center gap-3 overflow-hidden")
                    div(class="w-8 h-8 rounded bg-white border border-slate-200 flex items-center justify-center text-[10px] font-bold text-red-500") PDF
                    div(class="truncate")
                      p(class="text-sm font-bold text-slate-700 truncate group-hover:text-green-700 transition-colors") #{file.name}
                      p(class="text-[10px] text-slate-500") #{file.size} • #{file.date}
                  button(class="text-slate-400 hover:text-green-600 transition-colors") ⬇️
            
            button(class="w-full mt-6 py-2 border-2 border-dashed border-green-200 text-green-600 font-bold rounded-xl hover:bg-green-50 hover:border-green-400 transition-all text-sm") Upload New Document