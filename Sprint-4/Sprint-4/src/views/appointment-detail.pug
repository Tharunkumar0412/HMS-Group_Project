extends layouts/main

block content
  div(class="flex min-h-screen bg-slate-50 font-sans")
    aside(class="w-64 bg-green-900 text-white p-6 hidden md:flex flex-col justify-between")
      div
        h2(class="text-xl font-extrabold mb-10 border-b border-green-800 pb-4") HMS-Care
        nav(class="space-y-2")
          a(href="/dashboard/doctor" class="flex items-center gap-3 text-green-200 hover:bg-green-800 p-3 rounded-lg font-medium") Overview
          a(href="/dashboard/doctor/schedule" class="flex items-center gap-3 bg-green-800 border-l-4 border-green-400 text-white p-3 rounded-r-lg font-bold") My Schedule
          a(href="/dashboard/doctor/directory" class="flex items-center gap-3 text-green-200 hover:bg-green-800 p-3 rounded-lg font-medium") Patient Directory
          a(href="/profile/edit" class="flex items-center gap-3 text-green-200 hover:bg-green-800 p-3 rounded-lg font-medium") My Profile
      div
        a(href="/auth/logout" class="block w-full text-center bg-red-500 hover:bg-red-600 p-3 rounded-xl font-bold") Logout

    main(class="flex-1 p-6 md:p-10 max-w-4xl mx-auto w-full")

      //- Appointment header
      div(class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6 md:p-8 mb-8")
        div(class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6")
          div
            p(class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1") Appointment ##{appt.id}
            h1(class="text-2xl font-black text-slate-800") #{appt.patient_name}
            p(class="text-sm text-slate-500 mt-1") #{appt.appt_date} at #{appt.appt_time} · #{appt.dept_name}
          span(class="self-start px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-wider " + (appt.status === 'Completed' ? 'bg-green-100 text-green-700' : appt.status === 'Cancelled' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700')) #{appt.status}

        div(class="bg-slate-50 rounded-2xl p-5 border border-slate-100")
          p(class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2") Reason for Visit
          p(class="text-slate-700 font-medium leading-relaxed") #{appt.problem_description || 'Not specified'}

      //- If completed — show what was recorded
      if appt.status === 'Completed'
        //- Doctor notes (only visible to doctor)
        if isDoctor && appt.doctor_notes
          div(class="bg-amber-50 rounded-3xl border border-amber-100 p-6 mb-6")
            h2(class="text-xs font-bold text-amber-600 uppercase tracking-widest mb-3 flex items-center gap-2")
              span 🔒
              | Doctor Notes (private)
            p(class="text-slate-700 font-medium leading-relaxed") #{appt.doctor_notes}

        //- Medications prescribed
        if meds.length
          div(class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6 mb-6")
            h2(class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4") Medications Prescribed
            div(class="space-y-3")
              each med in meds
                div(class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl border border-slate-100")
                  span(class="text-lg") 💊
                  div
                    p(class="font-bold text-slate-800 text-sm") #{med.name}
                    p(class="text-xs text-slate-500 mt-0.5") #{med.instructions}

        //- Diagnoses added
        if diags.length
          div(class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6 mb-6")
            h2(class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4") Diagnoses Recorded
            div(class="space-y-3")
              each diag in diags
                div(class="flex justify-between items-center p-3 bg-slate-50 rounded-xl border border-slate-100")
                  div
                    p(class="font-bold text-slate-800 text-sm") #{diag.name}
                    p(class="text-xs text-slate-500 mt-0.5") Diagnosed: #{diag.diagnosed_date}
                  span(class="text-[10px] font-black px-2 py-0.5 rounded-md uppercase " + (diag.status === 'Active' ? 'bg-blue-100 text-blue-700' : 'bg-slate-200 text-slate-600')) #{diag.status}

        if !meds.length && !diags.length && isDoctor
          p(class="text-sm text-slate-400 italic mb-6") No medications or diagnoses were recorded for this appointment.

      //- If not completed — show action form for doctor
      if isDoctor && (appt.status === 'Upcoming' || appt.status === 'In Progress')
        div(class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6 md:p-8 mb-6")
          h2(class="text-lg font-extrabold text-slate-800 mb-6 pb-4 border-b border-slate-100") Complete Appointment

          form(action=`/appointments/${appt.id}/complete` method="POST" class="space-y-8")

            //- Doctor notes
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Clinical Notes (private — patient will not see this)
              textarea(name="doctorNotes" rows="4" placeholder="Clinical observations, examination findings, follow-up instructions..." class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800 resize-none")

            //- Medications
            div
              div(class="flex items-center justify-between mb-3")
                label(class="text-xs font-bold text-slate-500 uppercase tracking-wider") Prescriptions
                button(type="button" onclick="addMed()" class="text-sm font-bold text-green-600 hover:text-green-700") ＋ Add medication
              div#medList(class="space-y-3")
              p#noMedMsg(class="text-sm text-slate-400 italic") No prescriptions added yet.

            //- Diagnoses
            div
              div(class="flex items-center justify-between mb-3")
                label(class="text-xs font-bold text-slate-500 uppercase tracking-wider") New Diagnoses
                button(type="button" onclick="addDiag()" class="text-sm font-bold text-green-600 hover:text-green-700") ＋ Add diagnosis
              div#diagList(class="space-y-3")
              p#noDiagMsg(class="text-sm text-slate-400 italic") No diagnoses added yet.

            div(class="flex flex-col sm:flex-row gap-4 pt-6 border-t border-slate-100")
              button(type="submit" class="flex-1 bg-green-600 hover:bg-green-700 text-white py-4 rounded-xl font-bold transition-all shadow-md") ✓ Mark Complete & Save
              a(href="/dashboard/doctor/schedule" class="flex-1 text-center py-4 rounded-xl font-bold border-2 border-slate-200 text-slate-500 hover:border-slate-300 hover:text-slate-700 transition-all") Cancel

        //- Cancel and Reschedule actions
        div(class="flex flex-col sm:flex-row gap-4")
          a(href=`/appointments/${appt.id}/reschedule` class="flex-1 text-center py-3 rounded-xl font-bold border-2 border-orange-200 text-orange-600 hover:bg-orange-50 transition-all") Reschedule Appointment
          form(action=`/appointments/${appt.id}/cancel` method="POST" class="flex-1")
            input(type="hidden" name="cancellationReason" value="Cancelled by doctor")
            button(type="submit" onclick="return confirm('Cancel this appointment?')" class="w-full py-3 rounded-xl font-bold border-2 border-red-200 text-red-600 hover:bg-red-50 transition-all") Cancel Appointment

  script.
    function removeRow(btn) {
      btn.closest('.med-row, .diag-row').remove();
      document.getElementById('noMedMsg').style.display = document.querySelectorAll('.med-row').length ? 'none' : '';
      document.getElementById('noDiagMsg').style.display = document.querySelectorAll('.diag-row').length ? 'none' : '';
    }

    function addMed() {
      document.getElementById('noMedMsg').style.display = 'none';
      const row = document.createElement('div');
      row.className = 'med-row grid grid-cols-1 md:grid-cols-2 gap-3 p-4 bg-slate-50 rounded-xl border border-slate-100';
      row.innerHTML = `
        <input type="text" name="medNames" placeholder="Medication name & strength (e.g. Metformin 500mg)" required
          class="px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800">
        <div class="flex gap-2">
          <input type="text" name="medInstructions" placeholder="Instructions (e.g. Twice daily after meals)"
            class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800">
          <button type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 font-bold px-2">✕</button>
        </div>`;
      document.getElementById('medList').appendChild(row);
    }

    function addDiag() {
      document.getElementById('noDiagMsg').style.display = 'none';
      const row = document.createElement('div');
      row.className = 'diag-row flex gap-3 p-4 bg-slate-50 rounded-xl border border-slate-100 items-center';
      row.innerHTML = `
        <input type="text" name="diagNames" placeholder="Diagnosis name (e.g. Type 2 Diabetes Mellitus)" required
          class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800">
        <select name="diagStatuses" class="w-36 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800">
          <option value="Active">Active</option>
          <option value="Chronic">Chronic</option>
          <option value="Resolving">Resolving</option>
          <option value="Resolved">Resolved</option>
        </select>
        <button type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 font-bold px-2">✕</button>`;
      document.getElementById('diagList').appendChild(row);
    }
