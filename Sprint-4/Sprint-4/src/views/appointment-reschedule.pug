extends layouts/main

block content
  div(class="min-h-screen bg-slate-50 font-sans flex items-center justify-center p-6")
    div(class="w-full max-w-lg bg-white rounded-3xl shadow-sm border border-slate-100 p-8")
      h1(class="text-2xl font-black text-slate-800 mb-2") Reschedule Appointment
      p(class="text-slate-500 font-medium mb-8") Patient: #{appt.patient_name}

      if req && req.query && req.query.error === 'slot_taken'
        div(class="bg-orange-50 border border-orange-200 text-orange-700 text-sm font-bold p-4 rounded-xl mb-6") ⚠️ That slot is already taken. Please choose another.

      form(action=`/appointments/${appt.id}/reschedule` method="POST" class="space-y-6")
        div
          label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") New Date *
          input(type="date" name="newDate" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800")

        div
          label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") New Time Slot *
          input(type="time" name="newSlot" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800")
          p(class="text-xs text-slate-400 mt-1") Enter time within your availability window. 20-min slots.

        div(class="flex gap-4 pt-4 border-t border-slate-100")
          button(type="submit" class="flex-1 py-3 bg-green-600 hover:bg-green-700 text-white font-bold rounded-xl transition-all") Confirm Reschedule
          a(href="/dashboard/doctor/schedule" class="flex-1 text-center py-3 border-2 border-slate-200 text-slate-500 font-bold rounded-xl hover:border-slate-300 transition-all") Cancel
