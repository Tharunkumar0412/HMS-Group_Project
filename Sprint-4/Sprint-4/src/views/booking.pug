extends layouts/main

block content
  include layouts/_nav

  +pageShell('patient','booking')
    div(class="text-xs text-slate-400 font-medium mb-5 flex items-center gap-1.5")
      a(href="/dashboard/patient" class="hover:text-slate-600") 🏠 Dashboard
      span /
      span Book Appointment

    if error === 'slot_taken'
      div(class="bg-orange-50 border border-orange-200 text-orange-700 text-sm font-bold p-4 rounded-xl mb-6") ⚠️ That slot was just taken. Please choose a different time.
    if error === 'missing_fields'
      div(class="bg-red-50 border border-red-200 text-red-700 text-sm font-bold p-4 rounded-xl mb-6") ⚠️ Please fill in all fields before confirming.

    div(class="flex items-center mb-8 max-w-lg")
      div(class="flex flex-col items-center")
        div#step1Dot(class="w-8 h-8 rounded-full bg-green-600 text-white shadow-md flex items-center justify-center text-sm font-black transition-all") 1
        span#step1Label(class="text-[10px] font-bold mt-1 text-green-700") Department
      div#connector1(class="flex-1 h-0.5 mb-4 bg-green-300")
      div(class="flex flex-col items-center")
        div#step2Dot(class="w-8 h-8 rounded-full bg-slate-200 text-slate-400 flex items-center justify-center text-sm font-black transition-all") 2
        span#step2Label(class="text-[10px] font-bold mt-1 text-slate-400") Doctor & Date
      div#connector2(class="flex-1 h-0.5 mb-4 bg-slate-200")
      div(class="flex flex-col items-center")
        div#step3Dot(class="w-8 h-8 rounded-full bg-slate-200 text-slate-400 flex items-center justify-center text-sm font-black transition-all") 3
        span#step3Label(class="text-[10px] font-bold mt-1 text-slate-400") Confirm

    div(class="max-w-3xl")

      //- Hidden submission form
      form#bookingForm(action="/booking/confirm" method="POST")
        input(type="hidden" id="hDoctorId"  name="doctorId")
        input(type="hidden" id="hDate"       name="date")
        input(type="hidden" id="hSlotTime"   name="slotTime")
        input(type="hidden" id="hProblem"    name="problemDescription")

      div#step1Panel(class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 md:p-8")
        h2(class="text-lg font-black text-slate-800 mb-1") Select a Specialty
        p(class="text-sm text-slate-500 mb-6") Choose the department that matches your concern.

        div(class="grid grid-cols-2 md:grid-cols-3 gap-3")
          each dept in departments
            label(class="cursor-pointer")
              input(type="radio" name="_dept" value=dept.id data-name=dept.name class="peer sr-only")
              div(class="h-full p-4 border-2 border-slate-100 rounded-xl text-center transition-all peer-checked:border-green-600 peer-checked:bg-green-50 hover:border-green-300 hover:bg-slate-50 group")
                div(class="text-2xl mb-2") #{dept.icon}
                p(class="font-bold text-slate-800 text-sm leading-snug") #{dept.name}
                p(class="text-[11px] text-slate-500 mt-1 leading-tight") #{dept.deptDesc}

        div(class="mt-8 pt-5 border-t border-slate-100 flex justify-end")
          button(type="button" onclick="goToStep2()" class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl font-bold transition-all shadow-md") Continue →

      div#step2Panel(class="hidden bg-white rounded-2xl shadow-sm border border-slate-100 p-6 md:p-8")
        h2(class="text-lg font-black text-slate-800 mb-1") Choose Doctor & Time
        p(class="text-sm text-slate-500 mb-6") Doctors available in <span id="selectedDeptName" class="font-semibold text-green-700">your selected department</span>.

        div#doctorGrid(class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6")
          p(class="text-sm text-slate-400 col-span-2 italic") Loading doctors...

        div#dateSlotSection(class="hidden")
          div(class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5")
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Preferred Date *
              input(type="date" id="dateInput" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 font-medium text-slate-800")

          //- Slot grid
          div
            label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Available Slots *
            div#slotContainer
              p(class="text-sm text-slate-400 italic") Pick a date to see available slots.

          //- Reason for visit
          div(class="mt-5")
            label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Reason for Visit *
            textarea(id="problemInput" rows="3" placeholder="Briefly describe your symptoms or reason for this appointment..." class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 font-medium text-slate-800 resize-none text-sm")

        div(class="mt-8 pt-5 border-t border-slate-100 flex justify-between")
          button(type="button" onclick="goToStep1()" class="px-6 py-3 font-bold text-slate-500 hover:text-slate-800 transition-colors") ← Back
          button(type="button" onclick="confirmBooking()" class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl font-bold transition-all shadow-md") Confirm Appointment →

  script.
    var selectedDoctorId = null;
    var selectedSlot     = null;

    function setStepUI(step) {
      for (var i = 1; i <= 3; i++) {
        var dot   = document.getElementById('step' + i + 'Dot');
        var label = document.getElementById('step' + i + 'Label');
        var conn  = document.getElementById('connector' + i);
        if (i < step) {
          dot.className   = dot.className.replace('bg-slate-200 text-slate-400','bg-green-600 text-white shadow-md');
          label.className = label.className.replace('text-slate-400','text-green-700');
          if (conn) conn.className = conn.className.replace('bg-slate-200','bg-green-300');
        } else if (i === step) {
          dot.className   = dot.className.replace('bg-slate-200 text-slate-400','bg-green-600 text-white shadow-md');
          label.className = label.className.replace('text-slate-400','text-green-700');
        } else {
          dot.className   = dot.className.replace('bg-green-600 text-white shadow-md','bg-slate-200 text-slate-400');
          label.className = label.className.replace('text-green-700','text-slate-400');
        }
      }
    }

    function goToStep2() {
      var checked = document.querySelector('input[name="_dept"]:checked');
      if (!checked) { alert('Please select a department to continue.'); return; }

      var deptId   = checked.value;
      var deptName = checked.dataset.name;

      document.getElementById('selectedDeptName').textContent = deptName;
      document.getElementById('step1Panel').classList.add('hidden');
      document.getElementById('step2Panel').classList.remove('hidden');
      setStepUI(2);

      loadDoctors(deptId);
    }

    function goToStep1() {
      document.getElementById('step2Panel').classList.add('hidden');
      document.getElementById('step1Panel').classList.remove('hidden');
      setStepUI(1);
      selectedDoctorId = null;
      selectedSlot     = null;
    }

    async function loadDoctors(deptId) {
      var grid = document.getElementById('doctorGrid');
      grid.innerHTML = '<p class="text-sm text-slate-400 col-span-2 italic">Loading doctors...</p>';

      try {
        var res  = await fetch('/booking/doctors?deptId=' + encodeURIComponent(deptId));
        var data = await res.json();

        if (!data.doctors.length) {
          grid.innerHTML = '<p class="text-sm text-orange-500 font-bold col-span-2">No doctors available in this department yet.</p>';
          return;
        }

        grid.innerHTML = '';
        data.doctors.forEach(function(doc) {
          var card = document.createElement('label');
          card.className = 'cursor-pointer';
          card.innerHTML =
            '<input type="radio" name="_doctor" value="' + doc.id + '" class="peer sr-only">' +
            '<div class="p-4 border-2 border-slate-100 rounded-xl transition-all peer-checked:border-green-600 peer-checked:bg-green-50 hover:border-green-300 hover:bg-slate-50 h-full">' +
              '<div class="flex items-center gap-3 mb-2">' +
                '<div class="w-9 h-9 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-black text-sm shrink-0">' + doc.name.charAt(4) + '</div>' +
                '<div>' +
                  '<p class="font-bold text-slate-800 text-sm leading-snug">' + doc.name + '</p>' +
                  '<p class="text-xs text-slate-500">' + (doc.department || '') + '</p>' +
                '</div>' +
              '</div>' +
              (doc.bio ? '<p class="text-xs text-slate-400 leading-relaxed line-clamp-2">' + doc.bio + '</p>' : '') +
            '</div>';
          card.querySelector('input').addEventListener('change', function() {
            selectedDoctorId = doc.id;
            selectedSlot     = null;
            document.getElementById('dateSlotSection').classList.remove('hidden');
            document.getElementById('slotContainer').innerHTML = '<p class="text-sm text-slate-400 italic">Pick a date to see available slots.</p>';
          });
          grid.appendChild(card);
        });
      } catch(e) {
        grid.innerHTML = '<p class="text-sm text-red-500 col-span-2">Failed to load doctors.</p>';
      }
    }

    document.getElementById('dateInput').addEventListener('change', loadSlots);

    async function loadSlots() {
      var date = document.getElementById('dateInput').value;
      if (!selectedDoctorId || !date) return;

      var container = document.getElementById('slotContainer');
      container.innerHTML = '<p class="text-sm text-slate-400 italic">Loading slots...</p>';

      try {
        var res  = await fetch('/booking/slots?doctorId=' + selectedDoctorId + '&date=' + date);
        var data = await res.json();

        if (!data.slots.length) {
          container.innerHTML = '<p class="text-sm text-orange-500 font-bold">No available slots for this date. Try another day.</p>';
          return;
        }

        container.innerHTML = '<div class="flex flex-wrap gap-2" id="slotGrid"></div>';
        var grid = document.getElementById('slotGrid');
        data.slots.forEach(function(slot) {
          var btn = document.createElement('button');
          btn.type        = 'button';
          btn.textContent = slot.display;
          btn.dataset.val = slot.value;
          btn.className   = 'px-4 py-2 border-2 border-slate-200 rounded-xl font-bold text-slate-700 hover:border-green-500 hover:bg-green-50 transition-all text-sm';
          btn.addEventListener('click', function() {
            document.querySelectorAll('#slotGrid button').forEach(function(b) {
              b.className = 'px-4 py-2 border-2 border-slate-200 rounded-xl font-bold text-slate-700 hover:border-green-500 hover:bg-green-50 transition-all text-sm';
            });
            btn.className = 'px-4 py-2 border-2 border-green-600 bg-green-600 text-white rounded-xl font-bold transition-all text-sm';
            selectedSlot = slot.value;
          });
          grid.appendChild(btn);
        });
      } catch(e) {
        container.innerHTML = '<p class="text-sm text-red-500">Failed to load slots.</p>';
      }
    }

    function confirmBooking() {
      var date    = document.getElementById('dateInput').value;
      var problem = document.getElementById('problemInput').value.trim();

      if (!selectedDoctorId) { alert('Please select a doctor.'); return; }
      if (!date)              { alert('Please select a date.'); return; }
      if (!selectedSlot)      { alert('Please select a time slot.'); return; }
      if (!problem)           { alert('Please describe your reason for visit.'); return; }

      document.getElementById('hDoctorId').value = selectedDoctorId;
      document.getElementById('hDate').value      = date;
      document.getElementById('hSlotTime').value  = selectedSlot;
      document.getElementById('hProblem').value   = problem;
      document.getElementById('bookingForm').submit();
    }
