extends layouts/main

block content
  include layouts/_nav

  +pageShell('doctor','directory')

      div(class="text-xs text-slate-400 font-medium mb-4 flex items-center gap-1.5")
        a(href="/dashboard/doctor" class="hover:text-slate-600") 📊 Overview
        span /
        span Patient Directory

      header(class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6 bg-white p-5 rounded-2xl shadow-sm border border-slate-100")
        div
          h1(class="text-xl font-extrabold text-slate-800") Patient Directory
          p(class="text-sm text-slate-500 mt-0.5") All registered patients
        div(class="relative w-full md:w-64")
          input#searchInput(type="text" placeholder="Search name or ID..." class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800 text-sm bg-slate-50 focus:bg-white")
          span(class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm") 🔍

      if !patients || !patients.length
        div(class="text-center py-20")
          p(class="text-slate-400") No patients registered yet.
      else
        div#patientGrid(class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4")
          each patient in patients
            div(class="patient-card bg-white rounded-2xl p-5 border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all relative overflow-hidden")
              div(class="absolute -right-4 -top-4 w-20 h-20 bg-green-50 rounded-full -z-10")
              div(class="flex justify-between items-start mb-3")
                div(class="w-11 h-11 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 text-lg font-black border-2 border-white shadow-sm") #{patient.name.charAt(0)}
                span(class="text-[10px] font-bold px-2 py-0.5 rounded-md uppercase " + (patient.status === 'Active' ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-600')) #{patient.status}
              h3(class="text-base font-extrabold text-slate-800 patient-name") #{patient.name}
              p(class="text-xs font-bold text-slate-400 uppercase tracking-wide mb-3 patient-id") ID: #{patient.id}
              div(class="space-y-1.5 mb-4 text-xs")
                div(class="flex justify-between")
                  span(class="text-slate-500") Age/Gender
                  span(class="font-bold text-slate-700") #{patient.age} · #{patient.gender}
                div(class="flex justify-between")
                  span(class="text-slate-500") Blood Group
                  span(class="font-bold text-red-600") #{patient.bloodGroup}
                if patient.lastVisit
                  div(class="flex justify-between")
                    span(class="text-slate-500") Last Visit
                    span(class="font-bold text-slate-700") #{patient.lastVisit}
              a(href=`/dashboard/doctor/patient-view?patientId=${patient.id}` class="block w-full text-center px-4 py-2.5 bg-slate-50 hover:bg-green-600 hover:text-white border border-slate-100 hover:border-green-600 text-slate-700 text-sm font-bold rounded-xl transition-all") Open Record

  script.
    document.getElementById('searchInput').addEventListener('input', function() {
      var q = this.value.toLowerCase();
      document.querySelectorAll('.patient-card').forEach(function(card) {
        var name = card.querySelector('.patient-name').textContent.toLowerCase();
        var id   = card.querySelector('.patient-id').textContent.toLowerCase();
        card.style.display = (name.includes(q) || id.includes(q)) ? '' : 'none';
      });
    });
