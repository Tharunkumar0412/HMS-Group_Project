extends layouts/main

block content
  include layouts/_nav

  +pageShell('doctor','directory')

      div(class="text-xs text-slate-400 font-medium mb-4 flex items-center gap-1.5")
        a(href="/dashboard/doctor" class="hover:text-slate-600") 📊 Overview
        span /
        a(href="/dashboard/doctor/directory" class="hover:text-slate-600") Patient Directory
        span /
        span #{patient.name}

      header(class="bg-white p-5 md:p-6 rounded-2xl shadow-sm border border-slate-100 mb-6 flex flex-col xl:flex-row xl:items-center justify-between gap-5")
        div(class="flex items-center gap-4")
          div(class="w-14 h-14 rounded-full bg-slate-100 flex items-center justify-center text-2xl font-black border-3 border-white shadow-md") #{patient.name.charAt(0)}
          div
            div(class="flex items-center gap-3 mb-1")
              h1(class="text-xl font-black text-slate-800") #{patient.name}
              span(class="text-[10px] font-extrabold text-slate-500 bg-slate-100 px-2 py-0.5 rounded") #{patient.id}
            div(class="flex flex-wrap gap-2 text-sm text-slate-500")
              span(class="bg-slate-50 px-2.5 py-1 rounded-full border border-slate-100") #{patient.age} yrs, #{patient.gender}
              span(class="bg-red-50 text-red-700 px-2.5 py-1 rounded-full border border-red-100 font-bold") 🩸 #{patient.bloodGroup}
              if patient.lastVisit
                span(class="bg-blue-50 text-blue-700 px-2.5 py-1 rounded-full border border-blue-100") 🕒 #{patient.lastVisit}

      if patient.scopedToDoctor
        div(class="bg-blue-50 border border-blue-200 rounded-xl px-5 py-3 mb-4 flex items-center gap-3 text-sm")
          span(class="text-blue-500 text-base shrink-0") ℹ️
          div
            span(class="font-bold text-blue-800") Showing your records only.
            span(class="text-blue-600")  Appointments, diagnoses, and medications are scoped to visits with you. Other doctors' records are not shown here to prevent cross-prescribing.

      div(class="grid grid-cols-1 xl:grid-cols-3 gap-6")

        div(class="xl:col-span-2 space-y-6")

          div(class="grid grid-cols-2 md:grid-cols-4 gap-3")
            div(class="bg-white rounded-xl p-4 border border-slate-100 shadow-sm text-center")
              p(class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1") BP
              p(class="text-xl font-black text-slate-700") #{patient.vitals.bp}
            div(class="bg-white rounded-xl p-4 border border-slate-100 shadow-sm text-center")
              p(class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1") Heart Rate
              p(class="text-xl font-black text-slate-700") #{patient.vitals.hr}
            div(class="bg-white rounded-xl p-4 border border-slate-100 shadow-sm text-center")
              p(class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1") SpO2
              p(class="text-xl font-black text-slate-700") #{patient.vitals.spo2}
            div(class="bg-white rounded-xl p-4 border border-slate-100 shadow-sm text-center")
              p(class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1") Temp
              p(class="text-xl font-black text-slate-700") #{patient.vitals.temp}

          section(class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100")
            h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest mb-5 flex items-center gap-2")
              span(class="w-2 h-2 rounded-full bg-green-500")
              | Appointment History
            if !patient.apptHistory || !patient.apptHistory.length
              p(class="text-sm text-slate-400 italic") No appointment history.
            else
              div(class="space-y-3")
                each appt in patient.apptHistory
                  div(class="border border-slate-100 rounded-xl overflow-hidden hover:border-green-200 transition-colors")
                    div(class="flex items-center justify-between px-4 py-3 bg-slate-50")
                      div
                        p(class="font-bold text-slate-800 text-sm") #{appt.doctor_name}
                        p(class="text-xs text-slate-500") #{appt.appointment_date} · #{appt.dept_name}
                      div(class="flex items-center gap-2")
                        span(class="text-[10px] font-black px-2 py-0.5 rounded-md uppercase " + (appt.status === 'Completed' ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700')) #{appt.status}
                        a(href=`/appointments/${appt.id}` class="text-xs font-bold bg-white border border-slate-200 hover:border-blue-300 hover:bg-blue-50 text-blue-600 px-2.5 py-1 rounded-lg transition-all") View
                    div(class="px-4 py-3 border-t border-slate-100")
                      p(class="text-sm text-slate-600") #{appt.problem_description}

          //- Timeline with NOW marker
          section(class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100")
            h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest mb-5 flex items-center gap-2")
              span(class="w-2 h-2 rounded-full bg-blue-500")
              | Timeline
            if !patient.timeline || !patient.timeline.length
              p(class="text-sm text-slate-400 italic") No timeline events.
            else
              div(class="relative")
                div(class="absolute left-[18px] top-0 bottom-0 w-0.5 bg-slate-100")
                div(class="relative flex items-center gap-3 mb-3 z-10")
                  div(class="w-9 h-9 rounded-full bg-green-500 pulse-now flex items-center justify-center shrink-0 border-2 border-white shadow-md z-10")
                    span(class="text-white text-[10px] font-black") NOW
                  div(class="flex-1 bg-green-50 border border-green-200 rounded-xl px-3 py-2")
                    p(class="text-xs font-bold text-green-700") Present — Most recent first
                div(class="space-y-0")
                  each item, i in patient.timeline
                    div(class="relative flex gap-3 group")
                      div(class="flex flex-col items-center shrink-0 z-10")
                        div(class="w-9 h-9 rounded-full bg-white border-2 border-slate-200 flex items-center justify-center text-sm group-hover:border-blue-400 group-hover:bg-blue-50 transition-colors shadow-sm") ⚕️
                        if i < patient.timeline.length - 1
                          div(class="w-0.5 bg-slate-100 flex-1 min-h-4")
                      div(class="flex-1 pb-4 pt-1")
                        div(class="bg-slate-50 rounded-xl p-3 border border-slate-100 group-hover:bg-white group-hover:border-blue-200 group-hover:shadow-sm transition-all")
                          p(class="text-[10px] font-extrabold text-blue-600 tracking-wider mb-0.5") #{item.event_date}
                          p(class="font-bold text-slate-800 text-sm") #{item.title}
                          p(class="text-xs text-slate-500 mt-0.5 leading-relaxed") #{item.visit_desc}

        div(class="space-y-5")

          if patient.conditions && patient.conditions.length
            section(class="bg-blue-50 p-5 rounded-2xl border border-blue-100")
              h2(class="text-xs font-extrabold text-blue-600 uppercase tracking-widest mb-3") Pre-existing Conditions
              div(class="space-y-2")
                each c in patient.conditions
                  div(class="flex justify-between p-2.5 bg-white rounded-xl border border-blue-100 text-sm")
                    span(class="font-bold text-slate-700") #{c.condition_name}
                    if c.since_year
                      span(class="text-xs text-slate-400") #{c.since_year}

          section(class="bg-red-50 p-5 rounded-2xl border border-red-100")
            h2(class="text-xs font-extrabold text-red-600 uppercase tracking-widest mb-3 flex items-center gap-1.5") ⚠️ Allergies
            if !patient.allergies || !patient.allergies.length
              p(class="text-sm text-slate-400") No known allergies.
            else
              div(class="flex flex-wrap gap-2")
                each al in patient.allergies
                  span(class="text-xs font-bold px-3 py-1.5 rounded-xl " + (al.type === 'danger' ? 'bg-red-500 text-white' : 'bg-orange-100 text-orange-800 border border-orange-200')) #{al.name}

          section(class="bg-white p-5 rounded-2xl border border-slate-100")
            h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest mb-3") Problem List
            if !patient.diagnoses || !patient.diagnoses.length
              p(class="text-sm text-slate-400") No diagnoses recorded.
            else
              div(class="space-y-2")
                each diag in patient.diagnoses
                  div(class="p-3 bg-slate-50 rounded-xl border border-slate-100")
                    div(class="flex justify-between items-start mb-0.5")
                      p(class="font-bold text-slate-800 text-sm") #{diag.name}
                      span(class="text-[9px] font-black px-2 py-0.5 rounded-md uppercase " + (diag.status === 'Active' ? 'bg-blue-100 text-blue-700' : 'bg-slate-200 text-slate-600')) #{diag.status}
                    p(class="text-[11px] text-slate-500") #{diag.diagnosed_date}

          section(class="bg-white p-5 rounded-2xl border border-slate-100")
            h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest mb-3") Active Medications
            if !patient.medications || !patient.medications.length
              p(class="text-sm text-slate-400") No medications.
            else
              div(class="space-y-2")
                each med in patient.medications
                  div(class="flex gap-2.5 p-3 bg-slate-50 rounded-xl border border-slate-100")
                    span(class="shrink-0 text-base") 💊
                    div
                      p(class="font-bold text-slate-800 text-sm") #{med.name}
                      p(class="text-[11px] text-slate-500") #{med.instructions}
