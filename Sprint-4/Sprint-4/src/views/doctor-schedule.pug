extends layouts/main

block content
  include layouts/_nav

  +pageShell('doctor','schedule')

      div(class="text-xs text-slate-400 font-medium mb-4 flex items-center gap-1.5")
        a(href="/dashboard/doctor" class="hover:text-slate-600") 📊 Overview
        span /
        span My Schedule

      header(class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 bg-white p-5 rounded-2xl shadow-sm border border-slate-100")
        div
          h1(class="text-xl font-extrabold text-slate-800") Daily Schedule
          p(class="text-sm text-slate-500 mt-0.5") #{user.name}
        div(class="flex items-center gap-2")
          a(href="#" id="prevBtn" class="px-3 py-2 border-2 border-slate-100 rounded-xl font-bold text-slate-500 hover:border-slate-300 transition-all text-sm") ‹ Prev
          span(class="px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl font-bold text-slate-800 text-sm") #{date}
          a(href="#" id="nextBtn" class="px-3 py-2 border-2 border-slate-100 rounded-xl font-bold text-slate-500 hover:border-slate-300 transition-all text-sm") Next ›

      div(class="grid grid-cols-1 xl:grid-cols-3 gap-6")

        div(class="xl:col-span-2")
          div(class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden")
            div(class="px-5 py-4 border-b border-slate-100 bg-slate-50 flex justify-between items-center")
              h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest") Appointments
              span(class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-bold") #{schedule.length} booked
            if !schedule.length
              div(class="p-10 text-center")
                p(class="text-slate-400 text-sm") No appointments for this date.
            else
              div(class="divide-y divide-slate-100")
                each slot in schedule
                  div(class="px-5 py-4 hover:bg-slate-50 transition-colors")
                    div(class="flex flex-col sm:flex-row sm:items-center justify-between gap-3")
                      div(class="flex items-center gap-4")
                        div(class="w-18 shrink-0 text-right border-r-2 border-slate-100 pr-4 w-16")
                          p(class="text-sm font-black text-slate-800") #{slot.appt_time}
                        div
                          p(class="font-bold text-slate-800") #{slot.patient_name || 'Unknown'}
                          p(class="text-xs text-slate-500 mt-0.5 max-w-xs truncate") #{slot.problem_description}
                      div(class="flex items-center gap-2 shrink-0")
                        span(class="text-[10px] font-black px-2 py-1 rounded-md uppercase " + (slot.status === 'Completed' ? 'bg-green-100 text-green-700' : slot.status === 'Cancelled' ? 'bg-red-100 text-red-700' : 'bg-orange-100 text-orange-700')) #{slot.status}
                        if slot.status !== 'Completed' && slot.status !== 'Cancelled'
                          a(href=`/appointments/${slot.id}` class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-bold rounded-lg transition-all") Open
                        if slot.patient_id
                          a(href=`/dashboard/doctor/patient-view?patientId=${slot.patient_id}` class="px-3 py-1.5 bg-white border border-slate-200 hover:border-blue-300 hover:bg-blue-50 text-blue-600 text-xs font-bold rounded-lg transition-all") EHR

        div(class="space-y-5")

          //- Available slots with inline block button on each
          if allSlots && allSlots.length
            div(class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5")
              h2(class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2") Slots for This Day
              p(class="text-xs text-slate-400 mb-4") Click a free slot to block it.
              div(class="flex flex-wrap gap-2")
                each s in allSlots
                  - var isBooked = schedule.some(function(ap){ return ap.raw_time && ap.raw_time.substring(0,5) === s.substring(0,5); })
                  if isBooked
                    span(class="px-2.5 py-1.5 text-xs font-bold rounded-lg bg-blue-100 text-blue-700") #{s.substring(0,5)} Booked
                  else
                    form(action="/appointments/slots/block" method="POST" style="display:inline")
                      input(type="hidden" name="date" value=date)
                      input(type="hidden" name="slotTime" value=s)
                      button(type="submit" class="px-2.5 py-1.5 text-xs font-bold rounded-lg bg-slate-100 text-slate-600 hover:bg-orange-100 hover:text-orange-700 border border-transparent hover:border-orange-200 transition-all") #{s.substring(0,5)} ✕

          div(class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5")
            h2(class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2") Add Extra Slot
            p(class="text-xs text-slate-400 mb-3") One-time slot outside your usual hours.
            form(action="/appointments/slots/add" method="POST" class="flex gap-2")
              input(type="hidden" name="date" value=date)
              input(type="time" name="slotTime" required class="flex-1 px-3 py-2 rounded-xl border border-slate-200 outline-none focus:border-green-500 text-sm font-medium text-slate-800")
              button(type="submit" class="px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl text-sm") Add

          if overrides && overrides.length
            div(class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5")
              h2(class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3") Overrides Today
              div(class="space-y-2")
                each ov in overrides
                  div(class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100")
                    div
                      p(class="text-sm font-bold " + (ov.override_type === 'blocked' ? 'text-orange-700' : 'text-blue-700')) #{ov.slot_time.substring(0,5)} — #{ov.override_type}
                      if ov.reason
                        p(class="text-xs text-slate-500") #{ov.reason}
                    if ov.override_type === 'blocked'
                      form(action="/appointments/slots/unblock" method="POST")
                        input(type="hidden" name="date" value=date)
                        input(type="hidden" name="slotTime" value=ov.slot_time)
                        button(type="submit" class="text-xs text-red-500 hover:text-red-700 font-bold") Unblock

  script.
    var dateStr = '!{date}';
    var d = new Date(dateStr + 'T00:00:00');
    var prev = new Date(d); prev.setDate(d.getDate()-1);
    var next = new Date(d); next.setDate(d.getDate()+1);
    var fmt = function(dt){ return dt.toISOString().split('T')[0]; };
    document.getElementById('prevBtn').href = '/dashboard/doctor/schedule?date=' + fmt(prev);
    document.getElementById('nextBtn').href = '/dashboard/doctor/schedule?date=' + fmt(next);
