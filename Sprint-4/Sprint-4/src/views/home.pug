extends layouts/main

block content
  div(class="min-h-screen bg-white font-sans")

    //- ── Navbar ──────────────────────────────────────────────
    nav(class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-100 shadow-sm")
      div(class="max-w-7xl mx-auto px-5 sm:px-8 h-16 flex items-center justify-between")
        a(href="/" class="flex items-center gap-2.5")
          span(class="text-2xl leading-none") 🏥
          span(class="text-xl font-black text-green-900 tracking-tight") HMS-Care
        div(class="hidden md:flex items-center gap-8 text-sm font-semibold text-slate-600")
          a(href="#departments" class="hover:text-green-600 transition-colors") Departments
          a(href="#about" class="hover:text-green-600 transition-colors") About
          a(href="#contact" class="hover:text-green-600 transition-colors") Contact
        div(class="flex items-center gap-3")
          a(href="/login" class="text-sm font-bold text-slate-700 hover:text-green-700 transition-colors px-4 py-2") Sign In
          a(href="/signup" class="text-sm font-bold bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-xl transition-all shadow-md shadow-green-200") Get Started →

    //- ── Hero ────────────────────────────────────────────────
    section(class="relative overflow-hidden bg-white")
      //- Background gradient blobs
      div(class="absolute top-0 right-0 w-[600px] h-[600px] bg-gradient-to-bl from-green-50 to-transparent rounded-full -translate-y-1/4 translate-x-1/4 pointer-events-none")
      div(class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-to-tr from-blue-50 to-transparent rounded-full translate-y-1/4 -translate-x-1/4 pointer-events-none")

      div(class="max-w-7xl mx-auto px-5 sm:px-8 pt-20 pb-28 lg:pt-28 lg:pb-36 flex flex-col lg:flex-row items-center gap-16")
        //- Text
        div(class="flex-1 text-center lg:text-left z-10 max-w-2xl mx-auto lg:mx-0")
          div(class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-50 border border-green-100 text-green-700 text-xs font-bold uppercase tracking-widest mb-7")
            span(class="w-2 h-2 rounded-full bg-green-500 animate-pulse")
            | Trusted by 10,000+ patients

          h1(class="text-5xl md:text-6xl lg:text-7xl font-black text-slate-900 leading-[1.05] mb-7")
            | Advanced
            br
            span(class="text-transparent bg-clip-text bg-gradient-to-r from-green-600 to-emerald-400") Healthcare,
            br
            | Simplified.

          p(class="text-lg text-slate-500 mb-10 leading-relaxed font-medium")
            | Book appointments, access your medical records, and stay connected with your care team — all in one place.

          div(class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4")
            a(href="/signup" class="w-full sm:w-auto bg-green-600 hover:bg-green-700 text-white px-8 py-4 rounded-2xl font-bold text-base transition-all shadow-xl shadow-green-200 flex items-center justify-center gap-2")
              | Create Free Account
              span(class="text-lg") →
            a(href="/login" class="w-full sm:w-auto bg-slate-100 hover:bg-slate-200 text-slate-800 px-8 py-4 rounded-2xl font-bold text-base transition-all flex items-center justify-center gap-2")
              span(class="text-lg") 👨‍⚕️
              | Staff Login

          //- Trust bar
          div(class="mt-12 flex flex-wrap items-center justify-center lg:justify-start gap-6 text-sm text-slate-500 font-medium")
            div(class="flex items-center gap-2")
              span(class="text-green-600 font-black") ✓
              span No credit card required
            div(class="flex items-center gap-2")
              span(class="text-green-600 font-black") ✓
              span Free to sign up
            div(class="flex items-center gap-2")
              span(class="text-green-600 font-black") ✓
              span Instant access

        //- Image
        div(class="flex-1 relative w-full max-w-xl lg:max-w-none mx-auto z-10")
          div(class="absolute inset-0 bg-gradient-to-tr from-green-100 to-blue-50 rounded-[2.5rem] rotate-2 scale-105 -z-10")
          img(
            src="https://images.unsplash.com/photo-1551601651-2a8555f1a136?auto=format&fit=crop&w=1200&q=80"
            alt="Doctor consulting with patient"
            class="rounded-[2.5rem] shadow-2xl border-4 border-white object-cover h-[380px] lg:h-[520px] w-full"
          )
          //- Floating card
          div(class="absolute -bottom-5 -left-5 bg-white px-5 py-4 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-3")
            div(class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-xl shrink-0") ✅
            div
              p(class="text-xs font-bold text-slate-500 uppercase tracking-wide") Appointments Today
              p(class="text-xl font-black text-slate-800 leading-none") 48 Completed

    //- ── Stats bar ───────────────────────────────────────────
    section(class="bg-green-900 py-14")
      div(class="max-w-7xl mx-auto px-5 sm:px-8")
        div(class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center")
          div(class="p-4")
            p(class="text-4xl font-black text-white mb-1") 50+
            p(class="text-green-300 text-sm font-bold uppercase tracking-widest") Expert Doctors
          div(class="p-4 border-l border-green-800")
            p(class="text-4xl font-black text-white mb-1") 10k+
            p(class="text-green-300 text-sm font-bold uppercase tracking-widest") Patients Treated
          div(class="p-4 border-l border-green-800")
            p(class="text-4xl font-black text-white mb-1") 15+
            p(class="text-green-300 text-sm font-bold uppercase tracking-widest") Years Experience
          div(class="p-4 border-l border-green-800")
            p(class="text-4xl font-black text-white mb-1") 24/7
            p(class="text-green-300 text-sm font-bold uppercase tracking-widest") Emergency Care

    //- ── How it works ────────────────────────────────────────
    section#about(class="py-24 bg-slate-50")
      div(class="max-w-7xl mx-auto px-5 sm:px-8")
        div(class="text-center mb-16")
          p(class="text-green-600 font-bold uppercase tracking-widest text-sm mb-3") Simple Process
          h2(class="text-4xl font-black text-slate-900 mb-4") How HMS-Care Works
          p(class="text-slate-500 font-medium max-w-xl mx-auto") From signup to your first appointment in under 5 minutes.

        div(class="grid grid-cols-1 md:grid-cols-3 gap-8")
          div(class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center relative")
            div(class="w-14 h-14 bg-green-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5") 📝
            div(class="absolute top-6 right-8 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center text-sm font-black") 1
            h3(class="text-xl font-bold text-slate-800 mb-3") Create Account
            p(class="text-slate-500 text-sm leading-relaxed") Sign up as a patient or staff member. No credit card, no waiting — instant access.

          div(class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center relative")
            div(class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5") 👤
            div(class="absolute top-6 right-8 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center text-sm font-black") 2
            h3(class="text-xl font-bold text-slate-800 mb-3") Complete Profile
            p(class="text-slate-500 text-sm leading-relaxed") Fill in your medical history, allergies, and personal details. Doctors will have full context for your care.

          div(class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center relative")
            div(class="w-14 h-14 bg-purple-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5") 📅
            div(class="absolute top-6 right-8 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center text-sm font-black") 3
            h3(class="text-xl font-bold text-slate-800 mb-3") Book & Track
            p(class="text-slate-500 text-sm leading-relaxed") Book appointments with any doctor, view prescriptions, and track your complete medical history.

    //- ── Departments ─────────────────────────────────────────
    section#departments(class="py-24 bg-white")
      div(class="max-w-7xl mx-auto px-5 sm:px-8")
        div(class="text-center mb-16")
          p(class="text-green-600 font-bold uppercase tracking-widest text-sm mb-3") Specialties
          h2(class="text-4xl font-black text-slate-900 mb-4") Centers of Excellence
          p(class="text-slate-500 font-medium max-w-xl mx-auto") World-class specialists across every major medical discipline.

        div(class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6")
          each dept in [['❤️','Cardiology','Heart and cardiovascular system care','bg-red-50','text-red-600'],['🧠','Neurology','Brain and nervous system disorders','bg-blue-50','text-blue-600'],['🦴','Orthopedics','Bone, joint, and muscle care','bg-orange-50','text-orange-600'],['👁️','Ophthalmology','Comprehensive vision and eye care','bg-purple-50','text-purple-600'],['🩺','General Physician','Primary care and routine checkups','bg-green-50','text-green-600'],['👂','ENT Specialist','Ear, Nose, and Throat health','bg-pink-50','text-pink-600']]
            div(class="bg-white p-7 rounded-3xl border border-slate-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all group")
              div(class=`w-14 h-14 ${dept[3]} ${dept[4]} rounded-2xl flex items-center justify-center text-3xl mb-5 group-hover:scale-110 transition-transform`) #{dept[0]}
              h3(class="text-lg font-bold text-slate-800 mb-2") #{dept[1]}
              p(class="text-slate-500 text-sm leading-relaxed mb-5") #{dept[2]}
              a(href="/signup" class="text-green-600 font-bold text-sm flex items-center gap-1.5 group-hover:gap-2.5 transition-all")
                | Book Now
                span →

    //- ── CTA Banner ──────────────────────────────────────────
    section(class="py-20 bg-gradient-to-br from-green-900 to-green-800 relative overflow-hidden")
      div(class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?auto=format&fit=crop&w=2000&q=20')] bg-cover bg-center opacity-5")
      div(class="relative max-w-3xl mx-auto px-5 sm:px-8 text-center")
        h2(class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight")
          | Your Health Journey
          br
          span(class="text-green-400") Starts Here.
        p(class="text-green-100 text-lg font-medium mb-10 leading-relaxed")
          | Join thousands of patients who manage their health smarter with HMS-Care. Free to sign up, no commitments.
        div(class="flex flex-col sm:flex-row gap-4 justify-center")
          a(href="/signup" class="bg-white text-green-900 hover:bg-green-50 px-10 py-4 rounded-2xl font-black text-base transition-all shadow-xl flex items-center justify-center gap-2")
            | Create Free Account →
          a(href="/login" class="border-2 border-white/30 hover:border-white/60 text-white px-10 py-4 rounded-2xl font-bold text-base transition-all flex items-center justify-center gap-2")
            | Sign In

    //- ── Footer ──────────────────────────────────────────────
    footer#contact(class="bg-slate-900 py-12 border-t border-slate-800")
      div(class="max-w-7xl mx-auto px-5 sm:px-8")
        div(class="flex flex-col md:flex-row items-center justify-between gap-6")
          div(class="flex items-center gap-3")
            span(class="text-2xl") 🏥
            span(class="text-lg font-black text-white") HMS-Care
          p(class="text-slate-400 text-sm font-medium") © 2025 HMS-Care. All rights reserved.
          div(class="flex gap-6 text-sm font-bold text-slate-500")
            a(href="#" class="hover:text-white transition-colors") Privacy Policy
            a(href="#" class="hover:text-white transition-colors") Terms of Service
            a(href="/login" class="hover:text-white transition-colors text-green-500") Staff Login
