extends layouts/main

block content
  include layouts/_nav

  +pageShell('patient','dashboard')
    //- Breadcrumb
    div(class="text-xs text-slate-400 font-medium mb-5 flex items-center gap-1.5")
      span 🏠 Dashboard

    //- Header
    header(class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 bg-white p-5 rounded-2xl shadow-sm border border-slate-100")
      div(class="flex items-center gap-4")
        div(class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center text-green-700 text-xl font-black border-2 border-white shadow-sm") #{user.name.charAt(0)}
        div
          h1(class="text-xl font-black text-slate-800") Welcome back, #{user.name.split(' ')[0]}
          p(class="text-sm text-slate-500 mt-0.5")
            span(class="bg-slate-100 px-2 py-0.5 rounded text-xs font-bold") #{user.id}
            span  · #{user.gender} · #{user.bloodGroup}
      a(href="/booking/new" class="shrink-0 bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-xl font-bold text-sm transition-all shadow-md flex items-center gap-2")
        span ➕
        span Book Appointment

    div(class="grid grid-cols-1 xl:grid-cols-3 gap-6")
      div(class="xl:col-span-2 space-y-6")

        //- Upcoming appointments
        section(class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden")
          div(class="px-5 py-4 border-b border-slate-100 flex items-center justify-between")
            h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest flex items-center gap-2")
              span(class="w-2 h-2 rounded-full bg-orange-500")
              | Upcoming Appointments
            a(href="/booking/new" class="text-xs font-bold text-green-600 hover:text-green-800") + Book New
          if !upcoming || !upcoming.length
            div(class="p-8 text-center")
              p(class="text-slate-400 text-sm mb-3") No upcoming appointments.
              a(href="/booking/new" class="inline-block bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-xl font-bold text-sm") Book Your First Appointment
          else
            div(class="divide-y divide-slate-100")
              each appt in upcoming
                div(class="px-5 py-4 flex items-center gap-4 hover:bg-slate-50 transition-colors")
                  div(class="w-11 h-11 bg-white rounded-xl border-2 border-slate-100 flex flex-col items-center justify-center shadow-sm shrink-0")
                    p(class="text-[10px] font-black text-slate-500 leading-none uppercase") #{appt.appointment_date_raw ? new Date(appt.appointment_date_raw + 'T12:00:00').toLocaleDateString('en',{month:'short'}) : appt.appointment_date.split(' ')[0]}
                    p(class="text-base font-black text-green-600 leading-none") #{appt.appointment_date_raw ? new Date(appt.appointment_date_raw + 'T12:00:00').getDate() : appt.appointment_date.split(' ')[1].replace(',','')}
                  div(class="flex-1 min-w-0")
                    p(class="font-bold text-slate-800 text-sm") #{appt.doctor_name}
                    p(class="text-xs text-slate-500 truncate") #{appt.dept_name} · #{appt.appointment_time}
                    p(class="text-xs text-slate-400 truncate mt-0.5") #{appt.problem_description}
                  span(class="shrink-0 text-[10px] font-black px-2 py-1 rounded-full uppercase bg-orange-100 text-orange-700") #{appt.status}

        //- Vitals
        section(class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5")
          h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest flex items-center gap-2 mb-4")
            span(class="w-2 h-2 rounded-full bg-green-500")
            | Latest Vitals
          div(class="grid grid-cols-2 md:grid-cols-4 gap-3")
            div(class="bg-slate-50 rounded-xl p-4 border border-slate-100")
              p(class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1") Blood Pressure
              p(class="text-xl font-black text-slate-800") #{user.vitals.bp}
            div(class="bg-slate-50 rounded-xl p-4 border border-slate-100")
              p(class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1") Heart Rate
              p(class="text-xl font-black text-slate-800") #{user.vitals.hr} #[span(class="text-xs text-slate-400 font-normal") bpm]
            div(class="bg-slate-50 rounded-xl p-4 border border-slate-100")
              p(class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1") SpO2
              p(class="text-xl font-black text-slate-800") #{user.vitals.spo2}#[span(class="text-xs text-slate-400 font-normal") %]
            div(class="bg-slate-50 rounded-xl p-4 border border-slate-100")
              p(class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-1") Temperature
              p(class="text-xl font-black text-slate-800") #{user.vitals.temp}#[span(class="text-xs text-slate-400 font-normal") °F]

        //- Timeline with NOW marker
        section(class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5")
          div(class="flex items-center justify-between mb-5")
            h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest flex items-center gap-2")
              span(class="w-2 h-2 rounded-full bg-blue-500")
              | Visit Timeline
            a(href="/dashboard/patient/records" class="text-xs font-bold text-green-600 hover:text-green-800") View All →
          if !user.timeline || !user.timeline.length
            p(class="text-sm text-slate-400 italic text-center py-6") No visits recorded yet.
          else
            div(class="relative pl-10")
              //- Vertical connector line
              div(class="absolute left-4 top-0 bottom-0 w-0.5 bg-slate-100")

              //- NOW marker
              div(class="relative -ml-10 flex items-center gap-3 mb-4")
                div(class="w-8 h-8 rounded-full bg-green-500 pulse-now border-2 border-white shadow-md flex items-center justify-center shrink-0")
                  span(class="text-white text-[9px] font-black leading-none") NOW
                div(class="flex-1 bg-green-50 border border-green-200 rounded-xl px-3 py-1.5")
                  p(class="text-xs font-semibold text-green-700") Present — most recent first

              each item, idx in user.timeline
                div(class="relative -ml-10 flex gap-3 mb-0")
                  div(class="flex flex-col items-center shrink-0")
                    div(class="w-8 h-8 rounded-full bg-white border-2 border-slate-200 flex items-center justify-center text-sm shadow-sm z-10") ⚕️
                    if idx < user.timeline.length - 1
                      div(class="w-0.5 bg-slate-100 flex-1")
                  div(class="flex-1 pb-4 pt-0.5")
                    div(class="bg-slate-50 rounded-xl px-3 py-2.5 border border-slate-100")
                      p(class="text-[10px] font-extrabold text-blue-600 tracking-wide mb-0.5") #{item.event_date}
                      p(class="font-bold text-slate-800 text-sm leading-snug") #{item.title}
                      p(class="text-xs text-slate-500 mt-0.5 leading-relaxed") #{item.visit_desc}

      //- Right column
      div(class="space-y-5")
        if user.conditions && user.conditions.length
          section(class="bg-blue-50 rounded-2xl border border-blue-100 p-5")
            h2(class="text-xs font-extrabold text-blue-600 uppercase tracking-widest mb-3") Pre-existing Conditions
            div(class="space-y-2")
              each c in user.conditions
                div(class="flex justify-between items-center p-2.5 bg-white rounded-xl border border-blue-100 text-sm")
                  span(class="font-semibold text-slate-700") #{c.condition_name}
                  if c.since_year
                    span(class="text-xs text-slate-400") #{c.since_year}

        section(class="bg-red-50 rounded-2xl border border-red-100 p-5")
          h2(class="text-xs font-extrabold text-red-600 uppercase tracking-widest mb-3") ⚠️ Allergies
          if !user.allergies || !user.allergies.length
            p(class="text-sm text-slate-400") No allergies recorded.
          else
            div(class="flex flex-wrap gap-2")
              each al in user.allergies
                span(class="text-xs font-bold px-3 py-1.5 rounded-lg " + (al.type === 'danger' ? 'bg-red-500 text-white' : 'bg-orange-100 text-orange-800 border border-orange-200')) #{al.name}

        section(class="bg-white rounded-2xl border border-slate-100 p-5")
          h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest mb-3") Active Diagnoses
          if !user.diagnoses || !user.diagnoses.length
            p(class="text-sm text-slate-400") No diagnoses on record.
          else
            div(class="space-y-2")
              each diag in user.diagnoses
                div(class="p-3 bg-slate-50 rounded-xl border border-slate-100")
                  div(class="flex justify-between items-start gap-2")
                    p(class="font-semibold text-slate-800 text-sm leading-snug") #{diag.name}
                    span(class="shrink-0 text-[9px] font-black px-2 py-0.5 rounded-md uppercase " + (diag.status === 'Active' ? 'bg-blue-100 text-blue-700' : diag.status === 'Chronic' ? 'bg-purple-100 text-purple-700' : 'bg-slate-200 text-slate-600')) #{diag.status}
