extends layouts/main

block content
  include layouts/_nav

  +pageShell('doctor','profile')

      div(class="text-xs text-slate-400 font-medium mb-4 flex items-center gap-1.5")
        a(href="/dashboard/doctor" class="hover:text-slate-600") 📊 Overview
        span /
        span Edit Profile

      h1(class="text-2xl font-black text-slate-800 mb-6") Edit Profile

      if error
        div(class="bg-red-50 border border-red-200 text-red-700 text-sm font-bold p-4 rounded-xl mb-6") ⚠️ #{error}

      div(class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 md:p-8")
        form(action="/profile/edit" method="POST")

          h2(class="text-base font-extrabold text-slate-800 mb-5 pb-4 border-b border-slate-100") Doctor Information

          div(class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5")
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Full Name *
              input(type="text" name="name" required value=doctor.name class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Department *
              select(name="dept_id" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800")
                each dept in departments
                  option(value=dept.id selected=(dept.id === doctor.dept_id)) #{dept.name}
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Phone *
              input(type="tel" name="phone" required value=doctor.phone class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")

          div(class="mb-7")
            label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Bio
            textarea(name="bio" rows="3" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800 resize-none")= doctor.bio

          h2(class="text-base font-extrabold text-slate-800 mb-2 pb-4 border-b border-slate-100") Daily Availability
          p(class="text-sm text-slate-500 mb-5") Changes apply to all future days. Each window generates 20-min slots.

          div#availabilityList(class="space-y-3 mb-4")
            each w in availability
              div(class="availability-row flex items-center gap-3")
                input(type="time" name="start_times" value=w.start_time required class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800")
                span(class="text-slate-400 font-bold text-sm") to
                input(type="time" name="end_times" value=w.end_time required class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800")
                button(type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 transition-colors font-bold px-2 text-lg") ✕

          button(type="button" onclick="addRow()" class="text-sm font-bold text-green-600 hover:text-green-700 flex items-center gap-2 mb-7")
            span ＋
            span Add time window

          button(type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white py-4 rounded-xl font-bold transition-all shadow-lg") Save Changes

  script.
    function removeRow(btn) { btn.closest('.availability-row').remove(); }
    function addRow() {
      var row = document.createElement('div');
      row.className = 'availability-row flex items-center gap-3';
      row.innerHTML = '<input type="time" name="start_times" required class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800"><span class="text-slate-400 font-bold text-sm">to</span><input type="time" name="end_times" required class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800"><button type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 transition-colors font-bold px-2 text-lg">✕</button>';
      document.getElementById('availabilityList').appendChild(row);
    }
