extends layouts/main

block content
  div(class="min-h-screen bg-slate-50 font-sans flex items-start justify-center p-6 md:p-10")
    div(class="w-full max-w-2xl")

      //- Header
      div(class="text-center mb-10")
        div(class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4") 🏥
        h1(class="text-2xl font-black text-slate-800") Complete Your Profile
        p(class="text-slate-500 font-medium mt-2") This is required before you can access the system.

      if error
        div(class="bg-red-50 border border-red-200 text-red-700 text-sm font-bold p-4 rounded-xl mb-6") ⚠️ #{error}

      div(class="bg-white rounded-3xl shadow-sm border border-slate-100 p-8")

        if user.role === 'staff'
          //- ─── DOCTOR SETUP ───────────────────────────────────
          form(action="/profile/setup" method="POST" id="profileForm")
            h2(class="text-lg font-extrabold text-slate-800 mb-6 pb-4 border-b border-slate-100") Doctor Information

            div(class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6")
              div
                label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Full Name *
                input(type="text" name="name" required placeholder="Dr. Full Name" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")
              div
                label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Department *
                select(name="dept_id" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800")
                  option(value="" disabled selected) Select department...
                  each dept in departments
                    option(value=dept.id) #{dept.name}
              div
                label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Phone *
                input(type="tel" name="phone" required placeholder="+91 99999 99999" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")

            div(class="mb-8")
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Bio (optional)
              textarea(name="bio" rows="3" placeholder="Short professional summary..." class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800 resize-none")

            //- Availability
            h2(class="text-lg font-extrabold text-slate-800 mb-2 pb-4 border-b border-slate-100") Daily Availability *
            p(class="text-sm text-slate-500 mb-6") These time windows repeat every day. You can modify per-day from your schedule. Each window generates 20-min slots.

            div#availabilityList(class="space-y-3 mb-4")
              div(class="availability-row flex items-center gap-3")
                input(type="time" name="start_times" required class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800")
                span(class="text-slate-400 font-bold") to
                input(type="time" name="end_times" required class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800")
                button(type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 transition-colors font-bold px-2") ✕

            button(type="button" onclick="addAvailability()" class="text-sm font-bold text-green-600 hover:text-green-700 flex items-center gap-2 mb-8")
              span ＋
              span Add another time window

            button(type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white py-4 rounded-xl font-bold transition-all shadow-lg") Save Profile & Continue →

        else
          //- ─── PATIENT SETUP ──────────────────────────────────
          form(action="/profile/setup" method="POST" id="profileForm")
            h2(class="text-lg font-extrabold text-slate-800 mb-6 pb-4 border-b border-slate-100") Personal Information

            div(class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8")
              div
                label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Full Name *
                input(type="text" name="name" required placeholder="Full Name" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")
              div
                label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Age *
                input(type="number" name="age" required min="1" max="120" placeholder="Age" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")
              div
                label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Gender *
                select(name="gender" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800")
                  option(value="" disabled selected) Select gender...
                  option(value="Male") Male
                  option(value="Female") Female
                  option(value="Other") Other
              div
                label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Blood Group *
                select(name="blood_group" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800")
                  option(value="" disabled selected) Select blood group...
                  each bg in ['A+','A-','B+','B-','AB+','AB-','O+','O-']
                    option(value=bg) #{bg}
              div
                label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Phone *
                input(type="tel" name="phone" required placeholder="+91 99999 99999" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")
              div
                label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Emergency Contact *
                input(type="text" name="emergency_contact" required placeholder="Name — Phone" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")

            //- Pre-existing conditions
            h2(class="text-lg font-extrabold text-slate-800 mb-2 pb-4 border-b border-slate-100") Pre-existing Conditions
            p(class="text-sm text-slate-500 mb-4") Add any known health conditions so doctors have context.
            div#conditionsList(class="space-y-3 mb-4")
            button(type="button" onclick="addCondition()" class="text-sm font-bold text-green-600 hover:text-green-700 flex items-center gap-2 mb-8")
              span ＋
              span Add condition

            //- Allergies
            h2(class="text-lg font-extrabold text-slate-800 mb-2 pb-4 border-b border-slate-100") Known Allergies
            p(class="text-sm text-slate-500 mb-4") Add any allergies for doctor safety checks.
            div#allergiesList(class="space-y-3 mb-4")
            button(type="button" onclick="addAllergy()" class="text-sm font-bold text-green-600 hover:text-green-700 flex items-center gap-2 mb-8")
              span ＋
              span Add allergy

            button(type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white py-4 rounded-xl font-bold transition-all shadow-lg") Save Profile & Continue →

  script.
    function removeRow(btn) { btn.closest('.availability-row, .condition-row, .allergy-row').remove(); }

    function addAvailability() {
      const row = document.createElement('div');
      row.className = 'availability-row flex items-center gap-3';
      row.innerHTML = `
        <input type="time" name="start_times" required class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800">
        <span class="text-slate-400 font-bold">to</span>
        <input type="time" name="end_times" required class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800">
        <button type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 transition-colors font-bold px-2">✕</button>`;
      document.getElementById('availabilityList').appendChild(row);
    }

    function addCondition() {
      const row = document.createElement('div');
      row.className = 'condition-row flex items-center gap-3';
      row.innerHTML = `
        <input type="text" name="condition_names" placeholder="e.g. Type 2 Diabetes" class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800">
        <input type="number" name="condition_years" placeholder="Since year" min="1900" max="2099" class="w-32 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800">
        <button type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 font-bold px-2">✕</button>`;
      document.getElementById('conditionsList').appendChild(row);
    }

    function addAllergy() {
      const row = document.createElement('div');
      row.className = 'allergy-row flex items-center gap-3';
      row.innerHTML = `
        <input type="text" name="allergy_names" placeholder="e.g. Penicillin" class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800">
        <select name="allergy_types" class="w-36 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800">
          <option value="danger">Severe</option>
          <option value="warning" selected>Mild</option>
          <option value="info">Informational</option>
        </select>
        <button type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 font-bold px-2">✕</button>`;
      document.getElementById('allergiesList').appendChild(row);
    }
