extends layouts/main

block content
  include layouts/_nav

  +pageShell('patient','records')

      div(class="text-xs text-slate-400 font-medium mb-4 flex items-center gap-1.5")
        a(href="/dashboard/patient" class="hover:text-slate-600 transition-colors") 🏠 Dashboard
        span /
        span My Records

      header(class="bg-white p-5 rounded-2xl shadow-sm border border-green-100 mb-6 flex flex-col sm:flex-row sm:items-center gap-4")
        div(class="flex items-center gap-5")
          div(class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center text-green-700 text-2xl font-black") #{user.name.charAt(0)}
          div
            div(class="flex items-center gap-3 mb-1")
              h1(class="text-xl font-black text-slate-800") #{user.name}
              span(class="text-xs font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded") #{user.id}
            div(class="flex flex-wrap gap-3 text-sm text-slate-500 font-medium")
              span #{user.age} yrs · #{user.gender}
              span 🩸 #{user.bloodGroup}
              if user.lastVisit
                span Last visit: #{user.lastVisit}

      div(class="grid grid-cols-1 lg:grid-cols-3 gap-6")

        div(class="lg:col-span-2 space-y-6")

          section(class="bg-white p-5 rounded-2xl shadow-sm border border-green-100")
            h2(class="text-sm font-bold text-green-700 mb-5 flex items-center gap-2 uppercase tracking-widest")
              span 📅
              | Appointment History
            if !user.apptHistory || !user.apptHistory.length
              p(class="text-sm text-slate-400 italic") No appointments yet.
            else
              div(class="space-y-3")
                each appt in user.apptHistory
                  div(class="p-4 border border-slate-100 rounded-xl hover:border-green-200 transition-all")
                    div(class="flex items-center justify-between mb-2")
                      div
                        p(class="font-bold text-slate-800") #{appt.doctor_name}
                        p(class="text-xs text-slate-500") #{appt.appointment_date} · #{appt.dept_name}
                      span(class="text-[10px] font-black px-2 py-1 rounded-full uppercase bg-green-100 text-green-700") #{appt.status}
                    p(class="text-sm text-slate-600") #{appt.problem_description}
                    a(href=`/appointments/${appt.id}` class="inline-block mt-2 text-xs font-bold text-blue-600 hover:text-blue-800") View details →

          section(class="bg-white p-5 rounded-2xl shadow-sm border border-green-100")
            h2(class="text-sm font-bold text-green-700 mb-5 flex items-center gap-2 uppercase tracking-widest")
              span 📋
              | Diagnoses
            if !user.diagnoses || !user.diagnoses.length
              p(class="text-sm text-slate-400 italic") No diagnoses recorded.
            else
              div(class="divide-y divide-slate-100")
                each diag in user.diagnoses
                  div(class="py-4 first:pt-0 last:pb-0 flex justify-between items-center hover:bg-slate-50 px-2 rounded-lg transition-colors")
                    div
                      p(class="font-bold text-slate-800") #{diag.name}
                      p(class="text-xs text-slate-500 mt-1") Diagnosed: #{diag.diagnosed_date}
                    span(class="text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider " + (diag.status === 'Active' ? 'bg-blue-100 text-blue-700' : diag.status === 'Chronic' ? 'bg-purple-100 text-purple-700' : 'bg-slate-100 text-slate-600')) #{diag.status}

          section(class="bg-white p-5 rounded-2xl shadow-sm border border-green-100")
            h2(class="text-sm font-bold text-green-700 mb-5 flex items-center gap-2 uppercase tracking-widest")
              span 💊
              | Medications
            if !user.medications || !user.medications.length
              p(class="text-sm text-slate-400 italic") No medications prescribed yet.
            else
              div(class="space-y-3")
                each med in user.medications
                  div(class="flex items-center gap-4 p-4 border border-slate-100 rounded-xl hover:border-green-200 transition-all")
                    div(class="w-9 h-9 rounded-full bg-green-50 flex items-center justify-center text-green-600 shrink-0") 💊
                    div
                      p(class="font-bold text-slate-800") #{med.name}
                      p(class="text-xs text-slate-500 mt-1") #{med.instructions}
                      if med.prescribed_date
                        p(class="text-xs text-slate-400 mt-0.5") Prescribed: #{med.prescribed_date}

        div(class="space-y-5")

          section(class="bg-blue-50 p-5 rounded-2xl border border-blue-100")
            h2(class="text-sm font-bold text-blue-700 mb-4 uppercase tracking-widest") Pre-existing Conditions
            if !user.conditions || !user.conditions.length
              p(class="text-sm text-slate-400") None reported.
            else
              div(class="space-y-2")
                each c in user.conditions
                  div(class="flex justify-between p-2.5 bg-white rounded-xl border border-blue-100 text-sm")
                    span(class="font-bold text-slate-700") #{c.condition_name}
                    if c.since_year
                      span(class="text-xs text-slate-400") #{c.since_year}

          section(class="bg-red-50 p-5 rounded-2xl border border-red-100")
            h2(class="text-sm font-bold text-red-600 mb-4 flex items-center gap-2 uppercase tracking-widest")
              | ⚠️ Allergies
            if !user.allergies || !user.allergies.length
              p(class="text-sm text-slate-400") No known allergies.
            else
              div(class="flex flex-wrap gap-2")
                each al in user.allergies
                  span(class="text-xs font-bold px-3 py-1.5 rounded-lg " + (al.type === 'danger' ? 'bg-red-500 text-white' : 'bg-orange-100 text-orange-800 border border-orange-200')) #{al.name}

          section(class="bg-white p-5 rounded-2xl border border-green-100")
            h2(class="text-sm font-bold text-green-700 mb-4 uppercase tracking-widest") Medical Files
            if !user.medFiles || !user.medFiles.length
              p(class="text-sm text-slate-400") No files uploaded.
            else
              div(class="space-y-2")
                each file in user.medFiles
                  div(class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100 hover:bg-green-50 transition-colors group")
                    div(class="flex items-center gap-3 overflow-hidden")
                      div(class="w-8 h-8 rounded bg-white border border-slate-200 flex items-center justify-center text-[10px] font-bold text-red-500 shrink-0") PDF
                      div(class="truncate")
                        p(class="text-sm font-bold text-slate-700 truncate") #{file.name}
                        p(class="text-[10px] text-slate-500") #{file.size} · #{file.file_date}
                    button(class="text-slate-400 hover:text-green-600 transition-colors shrink-0") ⬇️
