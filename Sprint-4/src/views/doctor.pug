extends layouts/main

block content
  include layouts/_nav

  +pageShell('doctor','overview')

      div(class="text-xs text-slate-400 font-medium mb-4") 📊 Overview

      header(class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 bg-white p-5 rounded-2xl shadow-sm border border-slate-100")
        div(class="flex items-center gap-4")
          div(class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 text-xl font-black border-2 border-white shadow-sm") #{user.name.charAt(0)}
          div
            h1(class="text-xl font-black text-slate-800") Welcome, #{user.name}
            p(class="text-sm text-slate-500 mt-0.5") #{user.department}

      if user.urgent
        div(class="bg-red-50 border border-red-200 p-4 rounded-2xl flex items-center gap-4 mb-6 shadow-sm relative overflow-hidden")
          div(class="absolute left-0 top-0 bottom-0 w-1 bg-red-500 rounded-l-2xl")
          div(class="w-9 h-9 bg-red-100 rounded-full flex items-center justify-center text-red-600 shrink-0 animate-pulse pl-1") ⚠️
          div(class="flex-1 min-w-0")
            p(class="text-xs font-extrabold text-red-700 uppercase tracking-wide") Urgent Alert
            p(class="text-sm text-red-700 font-medium mt-0.5 truncate")
              span(class="font-bold") #{user.urgent.patient_name}:
              |  #{user.urgent.message}

      div(class="grid grid-cols-1 lg:grid-cols-3 gap-6")

        div(class="lg:col-span-2")
          section(class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden")
            div(class="px-5 py-4 border-b border-slate-100 bg-slate-50 flex justify-between items-center")
              h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest flex items-center gap-2")
                span(class="w-2 h-2 rounded-full bg-green-500")
                | Today's Schedule
              div(class="flex items-center gap-3")
                span(class="text-[10px] font-bold px-3 py-1 bg-green-100 text-green-700 rounded-full uppercase") #{user.schedule.length} Appointments
                a(href="/dashboard/doctor/schedule" class="text-xs font-bold text-blue-600 hover:text-blue-800") Full Schedule →
            if !user.schedule.length
              div(class="p-10 text-center")
                p(class="text-slate-400 font-medium text-sm") No appointments today.
            else
              div(class="divide-y divide-slate-100")
                each slot in user.schedule
                  div(class="px-5 py-4 flex flex-col sm:flex-row sm:items-center gap-3 hover:bg-slate-50 transition-colors group")
                    div(class="w-20 shrink-0")
                      p(class="text-sm font-extrabold text-slate-800") #{slot.appt_time}
                      span(class="text-[10px] font-bold px-2 py-0.5 rounded-md mt-1 inline-block " + (slot.status === 'Completed' ? 'bg-green-100 text-green-700' : slot.status === 'Cancelled' ? 'bg-red-100 text-red-700' : 'bg-orange-100 text-orange-700')) #{slot.status}
                    div(class="flex-1 min-w-0")
                      p(class="font-bold text-slate-800") #{slot.patient_name || '—'}
                      p(class="text-xs text-slate-500 truncate mt-0.5") #{slot.problem_description}
                    if slot.status !== 'Completed' && slot.status !== 'Cancelled'
                      div(class="flex items-center gap-2 shrink-0")
                        a(href=`/appointments/${slot.id}` class="px-3 py-2 bg-green-600 hover:bg-green-700 text-white text-xs font-bold rounded-lg transition-all") Open
                        if slot.patient_id
                          a(href=`/dashboard/doctor/patient-view?patientId=${slot.patient_id}` class="px-3 py-2 bg-white border border-slate-200 hover:border-blue-300 hover:bg-blue-50 text-blue-600 text-xs font-bold rounded-lg transition-all") EHR

        div(class="space-y-5")
          section(class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100")
            h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest mb-4") Shift Statistics
            div(class="space-y-3")
              div(class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100")
                div(class="flex items-center gap-2.5")
                  div(class="w-8 h-8 bg-green-100 text-green-700 rounded-full flex items-center justify-center text-sm") 👁
                  span(class="font-bold text-slate-700 text-sm") Total Visits
                span(class="text-xl font-black text-slate-800") #{user.stats.visits}
              div(class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100")
                div(class="flex items-center gap-2.5")
                  div(class="w-8 h-8 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-sm") 🔬
                  span(class="font-bold text-slate-700 text-sm") Pending Labs
                span(class="text-xl font-black text-slate-800") #{user.stats.labs}
              div(class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100")
                div(class="flex items-center gap-2.5")
                  div(class="w-8 h-8 bg-orange-100 text-orange-700 rounded-full flex items-center justify-center text-sm") 📁
                  span(class="font-bold text-slate-700 text-sm") Files to Review
                span(class="text-xl font-black text-slate-800") #{user.stats.files}
              div(class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100")
                div(class="flex items-center gap-2.5")
                  div(class="w-8 h-8 bg-red-100 text-red-700 rounded-full flex items-center justify-center text-sm") 🚨
                  span(class="font-bold text-slate-700 text-sm") Emergencies
                span(class="text-xl font-black text-slate-800") #{user.stats.emergencies}

          section(class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100")
            h2(class="text-xs font-extrabold text-slate-500 uppercase tracking-widest mb-3") Quick Actions
            div(class="space-y-2")
              a(href="/dashboard/doctor/directory" class="flex items-center gap-2.5 p-3 bg-slate-50 rounded-xl border border-slate-100 hover:border-green-300 hover:bg-green-50 transition-all text-sm font-bold text-slate-700") 👥 Patient Directory
              a(href="/dashboard/doctor/schedule" class="flex items-center gap-2.5 p-3 bg-slate-50 rounded-xl border border-slate-100 hover:border-green-300 hover:bg-green-50 transition-all text-sm font-bold text-slate-700") 📅 Manage Schedule
              a(href="/profile/edit" class="flex items-center gap-2.5 p-3 bg-slate-50 rounded-xl border border-slate-100 hover:border-green-300 hover:bg-green-50 transition-all text-sm font-bold text-slate-700") ✏️ Edit Profile & Availability
