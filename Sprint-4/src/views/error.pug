extends layouts/main

block content
  div(class="min-h-screen bg-slate-50 flex items-center justify-center font-sans p-6")
    div(class="max-w-md w-full bg-white rounded-3xl shadow-sm border border-slate-100 p-10 text-center")
      div(class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center text-3xl mx-auto mb-6") ⚠️
      h1(class="text-2xl font-black text-slate-800 mb-3") Something went wrong
      p(class="text-slate-500 font-medium mb-8 leading-relaxed") #{message || 'An unexpected error occurred. Please try again.'}
      div(class="flex flex-col sm:flex-row gap-3 justify-center")
        a(href="javascript:history.back()" class="px-6 py-3 border-2 border-slate-200 hover:border-slate-300 text-slate-600 font-bold rounded-xl transition-all") ← Go Back
        a(href="/" class="px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-bold rounded-xl transition-all shadow-md") Go Home
