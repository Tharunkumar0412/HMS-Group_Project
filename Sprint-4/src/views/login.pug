extends layouts/main

block content
  div(class="min-h-screen flex bg-slate-50 font-sans selection:bg-green-200 selection:text-green-900")
    
    //- Left Branding Panel (Hidden on mobile)
    div(class="hidden lg:flex lg:w-1/2 relative bg-green-900 overflow-hidden items-center justify-center")
      div(class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80')] bg-cover bg-center opacity-10 mix-blend-overlay")
      div(class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-green-900/95 to-green-800/95")
      
      div(class="relative z-10 p-12 text-white max-w-lg")
        div(class="inline-flex items-center justify-center w-16 h-16 bg-white/10 backdrop-blur-md rounded-2xl mb-8 border border-white/20 shadow-xl")
          span(class="text-3xl") 🏥
        
        h1(class="text-4xl md:text-5xl font-black tracking-tight mb-6 leading-tight") 
          | Next-Generation 
          br
          span(class="text-green-400") Healthcare 
          | Management
        
        p(class="text-green-100 text-lg leading-relaxed mb-10 font-medium") 
          | Secure, seamless, and efficient access to medical records, scheduling, and patient care for our dedicated staff and patients.
        
        div(class="flex gap-4 opacity-90")
          div(class="bg-white/10 backdrop-blur-sm p-4 rounded-2xl border border-white/10")
            p(class="text-2xl font-black text-white") 24/7
            p(class="text-[10px] text-green-200 uppercase tracking-widest font-bold mt-1") Secure Access
          div(class="bg-white/10 backdrop-blur-sm p-4 rounded-2xl border border-white/10")
            p(class="text-2xl font-black text-white") 100%
            p(class="text-[10px] text-green-200 uppercase tracking-widest font-bold mt-1") Encrypted

    div(class="flex-1 flex items-center justify-center p-6 sm:p-12")
      div(class="max-w-md w-full")
        
        //- Mobile Logo (Visible only on smaller screens)
        div(class="lg:hidden flex items-center gap-3 mb-8")
          div(class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center text-2xl shadow-sm") 🏥
          h1(class="text-2xl font-black text-slate-800") HMS <span class="text-green-600">Care</span>

        div(class="bg-white p-8 sm:p-10 rounded-[2rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100")
          div(class="mb-8 text-center sm:text-left")
            h2(class="text-2xl font-extrabold text-slate-900 mb-2") Welcome back
            p(class="text-sm text-slate-500 font-medium")
              | Don't have an account?
              a(href="/signup" class="text-green-600 font-bold hover:text-green-700 ml-1") Sign up free →

          if error === 'invalid_credentials'
            div(class="bg-red-50 border border-red-100 text-red-600 text-xs font-bold p-4 rounded-xl mb-6 flex items-start gap-3")
              span(class="text-base leading-none") ⚠️
              span Verification failed. Please verify your email, password, and access level.

          //- Role Toggle Switch
          div(class="flex p-1.5 bg-slate-50 rounded-xl mb-8 border border-slate-100")
            button#staffBtn(type="button" class="flex-1 py-3 text-[10px] uppercase tracking-widest font-bold bg-white rounded-lg shadow-sm text-green-700 transition-all border border-slate-100") Staff Access
            button#patientBtn(type="button" class="flex-1 py-3 text-[10px] uppercase tracking-widest font-bold text-slate-400 hover:text-slate-600 transition-all") Patient Portal

          form(action="/auth/login" method="POST" class="space-y-6")
            input#roleInput(type="hidden" name="role" value="staff")
            
            div
              label(class="block text-[10px] font-bold text-slate-500 mb-2 uppercase tracking-widest ml-1") Email Address
              div(class="relative")
                span(class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400") ✉️
                input(name="email" type="email" required placeholder="name@hms.com" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800 placeholder-slate-400 bg-white")
            
            div
              div(class="flex items-center justify-between mb-2 ml-1")
                label(class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest") Password
                a(href="#" class="text-[10px] font-bold text-green-600 hover:text-green-700 transition-colors") Forgot Password?
              div(class="relative")
                span(class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400") 🔒
                input(name="password" type="password" required placeholder="••••••••" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800 placeholder-slate-400 bg-white")
            
            button(type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-green-200 flex items-center justify-center gap-2 hover:-translate-y-0.5 mt-4")
              span Secure Login
              span →

  script.
    const sBtn = document.getElementById('staffBtn');
    const pBtn = document.getElementById('patientBtn');
    const rInp = document.getElementById('roleInput');

    const activeCls = 'flex-1 py-3 text-[10px] uppercase tracking-widest font-bold bg-white rounded-lg shadow-sm text-green-700 transition-all border border-slate-100';
    const inactiveCls = 'flex-1 py-3 text-[10px] uppercase tracking-widest font-bold text-slate-400 hover:text-slate-600 transition-all';

    sBtn.onclick = () => {
      rInp.value = 'staff';
      sBtn.className = activeCls;
      pBtn.className = inactiveCls;
    };
    pBtn.onclick = () => {
      rInp.value = 'patient';
      pBtn.className = activeCls;
      sBtn.className = inactiveCls;
    };