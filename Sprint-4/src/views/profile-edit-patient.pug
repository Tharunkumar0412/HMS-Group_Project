extends layouts/main

block content
  include layouts/_nav

  +pageShell('patient','profile')

      div(class="text-xs text-slate-400 font-medium mb-4 flex items-center gap-1.5")
        a(href="/dashboard/patient" class="hover:text-slate-600") 🏠 Dashboard
        span /
        span Edit Profile

      h1(class="text-2xl font-black text-slate-800 mb-6") Edit Profile

      if error
        div(class="bg-red-50 border border-red-200 text-red-700 text-sm font-bold p-4 rounded-xl mb-6") ⚠️ #{error}

      div(class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 md:p-8")
        form(action="/profile/edit" method="POST")

          h2(class="text-base font-extrabold text-slate-800 mb-5 pb-4 border-b border-slate-100") Personal Information

          div(class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-7")
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Full Name *
              input(type="text" name="name" required value=patient.name class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Age *
              input(type="number" name="age" required min="1" max="120" value=patient.age class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Gender *
              select(name="gender" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800")
                option(value="Male"   selected=(patient.gender==='Male'))   Male
                option(value="Female" selected=(patient.gender==='Female')) Female
                option(value="Other"  selected=(patient.gender==='Other'))  Other
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Blood Group *
              select(name="blood_group" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800")
                each bg in ['A+','A-','B+','B-','AB+','AB-','O+','O-']
                  option(value=bg selected=(bg===patient.blood_group)) #{bg}
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Phone *
              input(type="tel" name="phone" required value=patient.phone class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")
            div
              label(class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2") Emergency Contact *
              input(type="text" name="emergency_contact" required value=patient.emergency_contact class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800")

          h2(class="text-base font-extrabold text-slate-800 mb-2 pb-4 border-b border-slate-100") Pre-existing Conditions
          div#conditionsList(class="space-y-3 mb-4")
            each c in conditions
              div(class="condition-row flex items-center gap-3")
                input(type="text" name="condition_names" value=c.condition_name class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800")
                input(type="number" name="condition_years" value=c.since_year placeholder="Since year" min="1900" max="2099" class="w-28 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800")
                button(type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 font-bold px-2 text-lg") ✕
          button(type="button" onclick="addCondition()" class="text-sm font-bold text-green-600 hover:text-green-700 flex items-center gap-2 mb-7")
            span ＋
            span Add condition

          h2(class="text-base font-extrabold text-slate-800 mb-2 pb-4 border-b border-slate-100") Known Allergies
          div#allergiesList(class="space-y-3 mb-4")
            each al in allergies
              div(class="allergy-row flex items-center gap-3")
                input(type="text" name="allergy_names" value=al.name class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800")
                select(name="allergy_types" class="w-32 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800")
                  option(value="danger"  selected=(al.type==='danger'))  Severe
                  option(value="warning" selected=(al.type==='warning')) Mild
                  option(value="info"    selected=(al.type==='info'))    Info
                button(type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 font-bold px-2 text-lg") ✕
          button(type="button" onclick="addAllergy()" class="text-sm font-bold text-green-600 hover:text-green-700 flex items-center gap-2 mb-7")
            span ＋
            span Add allergy

          button(type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white py-4 rounded-xl font-bold transition-all shadow-lg") Save Changes

  script.
    function removeRow(btn) { btn.closest('.condition-row, .allergy-row').remove(); }
    function addCondition() {
      var row = document.createElement('div'); row.className = 'condition-row flex items-center gap-3';
      row.innerHTML = '<input type="text" name="condition_names" placeholder="e.g. Type 2 Diabetes" class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800"><input type="number" name="condition_years" placeholder="Since year" min="1900" max="2099" class="w-28 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800"><button type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 font-bold px-2 text-lg">✕</button>';
      document.getElementById('conditionsList').appendChild(row);
    }
    function addAllergy() {
      var row = document.createElement('div'); row.className = 'allergy-row flex items-center gap-3';
      row.innerHTML = '<input type="text" name="allergy_names" placeholder="e.g. Penicillin" class="flex-1 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 font-medium text-slate-800"><select name="allergy_types" class="w-32 px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 bg-white font-medium text-slate-800"><option value="danger">Severe</option><option value="warning" selected>Mild</option><option value="info">Info</option></select><button type="button" onclick="removeRow(this)" class="text-slate-400 hover:text-red-500 font-bold px-2 text-lg">✕</button>';
      document.getElementById('allergiesList').appendChild(row);
    }
