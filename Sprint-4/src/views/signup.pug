extends layouts/main

block content
  div(class="min-h-screen flex bg-slate-50 font-sans")

    //- Left branding panel
    div(class="hidden lg:flex lg:w-1/2 relative bg-green-900 overflow-hidden items-center justify-center")
      div(class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1581595220892-b0739db3ba8c?auto=format&fit=crop&w=1000&q=80')] bg-cover bg-center opacity-10")
      div(class="absolute inset-0 bg-gradient-to-br from-green-900/95 to-green-800/95")
      div(class="relative z-10 p-12 text-white max-w-lg")
        div(class="inline-flex items-center justify-center w-16 h-16 bg-white/10 backdrop-blur-md rounded-2xl mb-8 border border-white/20 shadow-xl")
          span(class="text-3xl") 🏥
        h1(class="text-4xl font-black tracking-tight mb-6 leading-tight")
          | Join HMS-Care
          br
          span(class="text-green-400") Your Health,
          |  Our Priority.
        p(class="text-green-100 text-lg leading-relaxed mb-10 font-medium") Create your account in seconds and get immediate access to appointments, records, and our expert medical team.
        div(class="space-y-4")
          div(class="flex items-center gap-3 text-green-100")
            div(class="w-8 h-8 bg-green-600 rounded-full flex items-center justify-center text-sm font-black shrink-0") 1
            span(class="font-medium") Create your account
          div(class="flex items-center gap-3 text-green-100")
            div(class="w-8 h-8 bg-green-700 rounded-full flex items-center justify-center text-sm font-black shrink-0") 2
            span(class="font-medium") Complete your profile
          div(class="flex items-center gap-3 text-green-100")
            div(class="w-8 h-8 bg-green-800 rounded-full flex items-center justify-center text-sm font-black shrink-0") 3
            span(class="font-medium") Book appointments or manage patients

    //- Right form panel
    div(class="flex-1 flex items-center justify-center p-6 sm:p-12")
      div(class="max-w-md w-full")

        //- Mobile logo
        div(class="lg:hidden flex items-center gap-3 mb-8")
          div(class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center text-xl") 🏥
          h1(class="text-xl font-black text-slate-800") HMS-Care

        div(class="bg-white p-8 sm:p-10 rounded-[2rem] shadow-sm border border-slate-100")
          div(class="mb-7")
            h2(class="text-2xl font-extrabold text-slate-900 mb-1") Create Account
            p(class="text-sm text-slate-500 font-medium")
              | Already have an account?
              a(href="/login" class="text-green-600 font-bold hover:text-green-700 ml-1") Sign in →

          if error
            div(class="bg-red-50 border border-red-100 text-red-600 text-xs font-bold p-4 rounded-xl mb-6 flex items-start gap-3")
              span ⚠️
              span #{error}

          //- Role toggle
          div(class="flex p-1.5 bg-slate-50 rounded-xl mb-6 border border-slate-100")
            button#patientBtn(type="button"
              class="flex-1 py-3 text-[10px] uppercase tracking-widest font-bold rounded-lg transition-all " + (values.role === 'staff' ? 'text-slate-400 hover:text-slate-600' : 'bg-white shadow-sm text-green-700 border border-slate-100'))
              | Patient Account
            button#staffBtn(type="button"
              class="flex-1 py-3 text-[10px] uppercase tracking-widest font-bold rounded-lg transition-all " + (values.role === 'staff' ? 'bg-white shadow-sm text-green-700 border border-slate-100' : 'text-slate-400 hover:text-slate-600'))
              | Staff / Doctor

          form(action="/auth/signup" method="POST" class="space-y-4")
            input#roleInput(type="hidden" name="role" value=values.role === 'staff' ? 'staff' : 'patient')

            div
              label(class="block text-[10px] font-bold text-slate-500 mb-2 uppercase tracking-widest") Email Address
              div(class="relative")
                span(class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400") ✉️
                input(
                  name="email" type="email" required
                  value=values.email || ''
                  placeholder="name@example.com"
                  class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800"
                )

            div
              label(class="block text-[10px] font-bold text-slate-500 mb-2 uppercase tracking-widest") Password
              div(class="relative")
                span(class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400") 🔒
                input(
                  name="password" type="password" required
                  placeholder="Minimum 8 characters"
                  class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800"
                )

            div
              label(class="block text-[10px] font-bold text-slate-500 mb-2 uppercase tracking-widest") Confirm Password
              div(class="relative")
                span(class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400") 🔒
                input(
                  name="confirmPassword" type="password" required
                  placeholder="Re-enter your password"
                  class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800"
                )

            p(class="text-[11px] text-slate-400 leading-relaxed") After signing up you'll be asked to complete your profile before accessing the system.

            button(type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-green-200 flex items-center justify-center gap-2 mt-2")
              span Create Account →

  script.
    const pBtn  = document.getElementById('patientBtn');
    const sBtn  = document.getElementById('staffBtn');
    const rInp  = document.getElementById('roleInput');
    const on    = 'flex-1 py-3 text-[10px] uppercase tracking-widest font-bold rounded-lg bg-white shadow-sm text-green-700 border border-slate-100 transition-all';
    const off   = 'flex-1 py-3 text-[10px] uppercase tracking-widest font-bold rounded-lg text-slate-400 hover:text-slate-600 transition-all';

    function setRole(role) {
      rInp.value = role;
      pBtn.className = role === 'patient' ? on : off;
      sBtn.className = role === 'staff'   ? on : off;
    }

    pBtn.addEventListener('click', () => setRole('patient'));
    sBtn.addEventListener('click', () => setRole('staff'));
