extends layouts/main

block content
  div(class="flex flex-col md:flex-row min-h-screen bg-slate-50 font-sans")
    
    //- Mobile Header
    div(class="md:hidden bg-green-800 text-white p-4 flex justify-between items-center shadow-md z-20 relative")
      div(class="flex items-center gap-2")
        span(class="text-2xl") 
        h2(class="text-lg font-bold tracking-wide") HMS-Care
      button#mobileMenuBtn(class="text-white focus:outline-none p-2 rounded-lg hover:bg-green-700 transition-colors")
        svg(class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16")

    //- Doctor's Sidebar
    aside#sidebar(class="fixed inset-y-0 left-0 transform -translate-x-full md:relative md:translate-x-0 transition-transform duration-300 ease-in-out z-50 w-64 bg-green-900 text-white flex flex-col justify-between shadow-2xl md:shadow-lg")
      div(class="p-6")
        div(class="hidden md:flex items-center gap-3 mb-10 border-b border-green-800 pb-6")
          span(class="text-3xl") 
          h2(class="text-xl font-extrabold tracking-wider text-green-50") Care
        
        nav(class="space-y-2 mt-8 md:mt-0")
          p(class="text-[10px] font-bold text-green-400 uppercase tracking-widest mb-4 px-3") Clinical Menu
          
          a(href="/dashboard/doctor" class="flex items-center gap-3 text-green-200 hover:bg-green-800 hover:text-white p-3 rounded-lg font-medium transition-all group")
            span(class="text-lg group-hover:scale-110 transition-transform") 
            span Overview
            
          a(href="/dashboard/doctor/schedule" class="flex items-center gap-3 text-green-200 hover:bg-green-800 hover:text-white p-3 rounded-lg font-medium transition-all group")
            span(class="text-lg group-hover:scale-110 transition-transform") 
            span My Schedule
            
          //- ACTIVE PAGE: Patient Directory
          a(href="/dashboard/doctor/directory" class="flex items-center gap-3 bg-green-800 border-l-4 border-green-400 text-white p-3 rounded-r-lg shadow-inner font-bold transition-all")
            span(class="text-lg") 
            span Patient Directory
      
      div(class="p-6 border-t border-green-800")
        a(href="/auth/logout" class="flex items-center justify-center gap-2 w-full bg-red-500 hover:bg-red-600 text-white p-3 rounded-xl font-bold transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5")
          span 
          span Secure Logout

    div#sidebarOverlay(class="fixed inset-0 bg-slate-900/50 z-40 hidden md:hidden backdrop-blur-sm transition-opacity")

    //- Main Content Area
    main(class="flex-1 p-4 md:p-8 w-full max-w-7xl mx-auto overflow-y-auto")
      
      header(class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 bg-white p-6 rounded-3xl shadow-sm border border-slate-100")
        div
          h2(class="text-2xl font-extrabold text-slate-800") Patient Directory
          p(class="text-sm text-slate-500 font-medium mt-1") Search and access master patient records.
        
        //- Search Bar
        div(class="relative w-full md:w-72")
          input(type="text" placeholder="Search by name or ID..." class="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800 bg-slate-50 focus:bg-white")
          span(class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg") 🔍

      //- Patient Grid
      div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6")
        each patient in patients
          div(class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all group relative overflow-hidden")
            //- Decorative background element
            div(class="absolute -right-6 -top-6 w-24 h-24 bg-green-50 rounded-full -z-10 group-hover:scale-150 transition-transform duration-500")
            
            div(class="flex justify-between items-start mb-4")
              div(class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 text-xl font-bold border-2 border-white shadow-sm") #{patient.name.charAt(0)}
              span(class="text-[10px] font-bold px-2 py-1 rounded-md uppercase tracking-wider " + (patient.status === 'Active' ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-600')) #{patient.status}
            
            h3(class="text-lg font-extrabold text-slate-800") #{patient.name}
            p(class="text-xs font-bold text-slate-400 uppercase tracking-wide mb-4") ID: #{patient.id}
            
            div(class="space-y-2 mb-6")
              div(class="flex justify-between text-sm")
                span(class="text-slate-500 font-medium") Age/Gender
                span(class="font-bold text-slate-700") #{patient.age} • #{patient.gender}
              div(class="flex justify-between text-sm")
                span(class="text-slate-500 font-medium") Blood Group
                span(class="font-bold text-red-600") #{patient.bloodGroup}
              div(class="flex justify-between text-sm")
                span(class="text-slate-500 font-medium") Last Visit
                span(class="font-bold text-slate-700") #{patient.lastVisit}
            
            //- Action Button (s to Ankith's mock EHR for prototype purposes)
            a(href="/dashboard/doctor/patient-view" class="block w-full text-center px-4 py-3 bg-slate-50 hover:bg-green-600 hover:text-white border border-slate-100 hover:border-green-600 text-slate-700 text-sm font-bold rounded-xl transition-all") Open Record

  script.
    const btn = document.getElementById('mobileMenuBtn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    function toggleMenu() { sidebar.classList.toggle('-translate-x-full'); overlay.classList.toggle('hidden'); }
    btn.addEventListener('click', toggleMenu);
    overlay.addEventListener('click', toggleMenu);