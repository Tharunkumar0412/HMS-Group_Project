extends layouts/main

block content
  div(class="flex flex-col md:flex-row min-h-screen bg-slate-50 font-sans")
    
    //- Mobile Header
    div(class="md:hidden bg-green-800 text-white p-4 flex justify-between items-center shadow-md z-20 relative")
      div(class="flex items-center gap-2")
        span(class="text-2xl") 
        h2(class="text-lg font-bold tracking-wide") HMS-Care
      button#mobileMenuBtn(class="text-white focus:outline-none p-2 rounded-lg hover:bg-green-700 transition-colors")
        svg(class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16")

    //- Doctor's Sidebar
    aside#sidebar(class="fixed inset-y-0 left-0 transform -translate-x-full md:relative md:translate-x-0 transition-transform duration-300 ease-in-out z-50 w-64 bg-green-900 text-white flex flex-col justify-between shadow-2xl md:shadow-lg")
      div(class="p-6")
        div(class="hidden md:flex items-center gap-3 mb-10 border-b border-green-800 pb-6")
          span(class="text-3xl") 
          h2(class="text-xl font-extrabold tracking-wider text-green-50") Care
        
        nav(class="space-y-2 mt-8 md:mt-0")
          p(class="text-[10px] font-bold text-green-400 uppercase tracking-widest mb-4 px-3") Clinical Menu
          
          a(href="/dashboard/doctor" class="flex items-center gap-3 text-green-200 hover:bg-green-800 hover:text-white p-3 rounded-lg font-medium transition-all group")
            span(class="text-lg group-hover:scale-110 transition-transform") 
            span Overview
            
          //- ACTIVE PAGE: My Schedule
          a(href="/dashboard/doctor/schedule" class="flex items-center gap-3 bg-green-800 border-l-4 border-green-400 text-white p-3 rounded-r-lg shadow-inner font-bold transition-all")
            span(class="text-lg") 
            span My Schedule
            
          a(href="/dashboard/doctor/directory" class="flex items-center gap-3 text-green-200 hover:bg-green-800 hover:text-white p-3 rounded-lg font-medium transition-all group")
            span(class="text-lg group-hover:scale-110 transition-transform") 
            span Patient Directory
      
      div(class="p-6 border-t border-green-800")
        a(href="/auth/logout" class="flex items-center justify-center gap-2 w-full bg-red-500 hover:bg-red-600 text-white p-3 rounded-xl font-bold transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5")
          span 
          span Secure Logout

    div#sidebarOverlay(class="fixed inset-0 bg-slate-900/50 z-40 hidden md:hidden backdrop-blur-sm transition-opacity")

    //- Main Content Area
    main(class="flex-1 p-4 md:p-8 w-full max-w-7xl mx-auto overflow-y-auto")
      
      header(class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 bg-white p-6 rounded-3xl shadow-sm border border-slate-100")
        div
          h2(class="text-2xl font-extrabold text-slate-800") Daily Schedule
          p(class="text-sm text-slate-500 font-medium mt-1") Manage your appointments and clinical blocks.
        div(class="flex items-center gap-3")
          button(class="px-4 py-2 border-2 border-slate-100 rounded-xl font-bold text-slate-500 hover:border-slate-300 hover:text-slate-800 transition-all") &lt;
          span(class="px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl font-bold text-slate-800") Today
          button(class="px-4 py-2 border-2 border-slate-100 rounded-xl font-bold text-slate-500 hover:border-slate-300 hover:text-slate-800 transition-all") &gt;

      div(class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden")
        div(class="p-6 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center")
          h3(class="text-xs font-extrabold text-slate-400 uppercase tracking-widest") Appointment Roster
          span(class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider") #{user.schedule.length} Slots Booked

        div(class="divide-y divide-slate-100")
          each slot in user.schedule
            div(class="p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:bg-slate-50 transition-colors group")
              div(class="flex items-center gap-6")
                div(class="w-24 shrink-0 border-r-2 border-slate-100 pr-4")
                  p(class="text-lg font-black text-slate-800") #{slot.time.split(' ')[0]}
                  p(class="text-xs font-bold text-slate-400 uppercase") #{slot.time.split(' ')[1]}
                
                div
                  div(class="flex items-center gap-3 mb-1")
                    p(class="text-lg font-bold text-slate-800") #{slot.name}
                    span(class="text-[10px] font-bold px-2 py-0.5 rounded-md uppercase tracking-wide " + (slot.status === 'Completed' ? 'bg-green-100 text-green-700' : slot.status === 'In Progress' ? 'bg-blue-100 text-blue-700' : 'bg-orange-100 text-orange-700')) #{slot.status}
                  p(class="text-sm text-slate-500 font-medium") #{slot.type}
              
              div(class="flex items-center gap-2 w-full sm:w-auto mt-4 sm:mt-0")
                a(href="/dashboard/doctor/patient-view" class="w-full sm:w-auto text-center px-6 py-2.5 bg-white border border-slate-200 hover:border-blue-300 hover:bg-blue-50 text-blue-600 text-sm font-bold rounded-xl transition-all shadow-sm") Open EHR

  script.
    const btn = document.getElementById('mobileMenuBtn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    function toggleMenu() { sidebar.classList.toggle('-translate-x-full'); overlay.classList.toggle('hidden'); }
    btn.addEventListener('click', toggleMenu);
    overlay.addEventListener('click', toggleMenu);