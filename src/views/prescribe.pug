extends layouts/main

block content
  div(class="flex flex-col md:flex-row min-h-screen bg-slate-50 font-sans")
    
    //- Mobile Header
    div(class="md:hidden bg-green-800 text-white p-4 flex justify-between items-center shadow-md z-20 relative")
      div(class="flex items-center gap-2")
        span(class="text-2xl")
        h2(class="text-lg font-bold tracking-wide") HMS-Care
      button#mobileMenuBtn(class="text-white focus:outline-none p-2 rounded-lg hover:bg-green-700 transition-colors")
        svg(class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16")

    //- Doctor's Sidebar
    aside#sidebar(class="fixed inset-y-0 left-0 transform -translate-x-full md:relative md:translate-x-0 transition-transform duration-300 ease-in-out z-50 w-64 bg-green-900 text-white flex flex-col justify-between shadow-2xl md:shadow-lg")
      div(class="p-6")
        div(class="hidden md:flex items-center gap-3 mb-10 border-b border-green-800 pb-6")
          span(class="text-3xl")
          h2(class="text-xl font-extrabold tracking-wider text-green-50") Care
        
        nav(class="space-y-2 mt-8 md:mt-0")
          p(class="text-[10px] font-bold text-green-400 uppercase tracking-widest mb-4 px-3") Clinical Menu
          
          a(href="/dashboard/doctor" class="flex items-center gap-3 text-green-200 hover:bg-green-800 hover:text-white p-3 rounded-lg font-medium transition-all")
            span(class="text-lg") ⬅️
            span Back to Overview
            
          a(href="/dashboard/doctor/patient-view" class="flex items-center gap-3 text-green-200 hover:bg-green-800 hover:text-white p-3 rounded-lg font-medium transition-all")
            span(class="text-lg") 📋
            span Patient EHR
      
      div(class="p-6 border-t border-green-800")
        a(href="/auth/logout" class="flex items-center justify-center gap-2 w-full bg-red-500 hover:bg-red-600 text-white p-3 rounded-xl font-bold transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5")
          span           Secure Logout

    div#sidebarOverlay(class="fixed inset-0 bg-slate-900/50 z-40 hidden md:hidden backdrop-blur-sm transition-opacity")

    //- Main Content Area
    main(class="flex-1 p-4 md:p-8 w-full max-w-4xl mx-auto overflow-y-auto")
      
      //- Patient Identification Banner
      header(class="bg-blue-50 p-6 rounded-2xl border border-blue-100 mb-8 flex items-center justify-between")
        div(class="flex items-center gap-4")
          div(class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-blue-600 text-xl font-bold border-2 border-blue-200 shadow-sm") 👤
          div
            p(class="text-xs font-bold text-blue-600 uppercase tracking-widest mb-0.5") Prescribing For
            h2(class="text-xl font-black text-slate-800 flex items-center gap-3") 
              | #{patient.name}
              span(class="text-[10px] font-extrabold text-slate-500 bg-white px-2 py-1 rounded-md tracking-wider border border-slate-200") ID: #{patient.id}
        
        //- Warning for Allergies
        if patient.allergies.length > 0
          div(class="hidden sm:flex items-center gap-2 bg-white px-4 py-2 rounded-xl border border-red-100 shadow-sm")
            span ⚠️
            div
              p(class="text-[10px] font-bold text-red-500 uppercase") Known Allergies
              p(class="text-xs font-bold text-slate-700") #{patient.allergies[0].name}

      //- Prescription Form
      div(class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100")
        h3(class="text-lg font-extrabold text-slate-800 mb-6 flex items-center gap-2") 
          span(class="text-green-600") 💊
          | New Prescription Details
        
        form(action="/dashboard/doctor/prescribe" method="POST" class="space-y-6")
          
          div
            label(class="block text-sm font-extrabold text-slate-700 mb-2") Medication Name & Strength
            input(type="text" name="medName" placeholder="e.g., Amoxicillin 500mg" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800 placeholder-slate-400 bg-slate-50 focus:bg-white")
            
          div
            label(class="block text-sm font-extrabold text-slate-700 mb-2") Dosage Instructions (Sig)
            input(type="text" name="instructions" placeholder="e.g., Take 1 tablet by mouth every 8 hours for 7 days" required class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:border-green-500 focus:ring-4 focus:ring-green-50 transition-all font-medium text-slate-800 placeholder-slate-400 bg-slate-50 focus:bg-white")

          div(class="pt-6 border-t border-slate-100 flex flex-col sm:flex-row gap-4 justify-end")
            a(href="/dashboard/doctor/patient-view" class="px-6 py-3 font-bold text-slate-500 hover:text-slate-800 hover:bg-slate-50 rounded-xl transition-all text-center") Cancel
            button(type="submit" class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl font-bold transition-all shadow-md shadow-green-200 flex items-center justify-center gap-2 hover:-translate-y-0.5") 
              span ✅
              span Authorize & Prescribe

  script.
    const btn = document.getElementById('mobileMenuBtn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    function toggleMenu() { sidebar.classList.toggle('-translate-x-full'); overlay.classList.toggle('hidden'); }
    btn.addEventListener('click', toggleMenu);
    overlay.addEventListener('click', toggleMenu);